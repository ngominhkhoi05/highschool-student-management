@using highschool_student_management.ViewModels
@{
    var teacherName = (string)ViewBag.TeacherName;
    var schoolYearName = (string)ViewBag.SchoolYearName;
    var currentSemesterName = (string)ViewBag.CurrentSemesterName;
    var isHomeroomTeacher = (bool)ViewBag.IsHomeroomTeacher;
    var homeroomClass = (HomeroomClassInfoViewModel)ViewBag.HomeroomClass;
    var teachingClasses = (List<TeacherClassItemViewModel>)ViewBag.TeachingClasses;
}

<div class="p-6 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Xin chào, @teacherName</h1>
            <p class="text-sm text-slate-500 mt-1">
                @(schoolYearName)
                @(string.IsNullOrEmpty(currentSemesterName) ? "" : " - " + currentSemesterName)
            </p>
        </div>
    </div>

    <!-- Khu vực lớp chủ nhiệm (nếu có) -->
    @if (isHomeroomTeacher && homeroomClass != null)
    {
        <div class="bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl p-6 text-white shadow-lg">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-3xl">meeting_room</span>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-green-100 uppercase tracking-wider">Lớp chủ nhiệm</p>
                        <p class="text-xl font-bold mt-0.5">@homeroomClass.ClassName @(homeroomClass.GradeLevel > 0 ? " - Khối " + homeroomClass.GradeLevel : "")</p>
                        <p class="text-sm text-green-100 mt-1">
                            @(homeroomClass.StudentCount) học sinh
                            @if (!string.IsNullOrEmpty(homeroomClass.Room))
                            {
                                <span> | Phòng @homeroomClass.Room</span>
                            }
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <a asp-controller="Homeroom" asp-action="MyClass"
                       class="flex items-center gap-2 px-4 py-2.5 bg-white/20 hover:bg-white/30 rounded-xl text-sm font-semibold transition-all">
                        <span class="material-symbols-outlined text-lg">visibility</span>
                        Xem lớp
                    </a>
                    <a asp-controller="Homeroom" asp-action="Violations"
                       class="flex items-center gap-2 px-4 py-2.5 bg-white/20 hover:bg-white/30 rounded-xl text-sm font-semibold transition-all">
                        <span class="material-symbols-outlined text-lg">report</span>
                        Vi phạm
                    </a>
                    <a asp-controller="Homeroom" asp-action="ConductScores"
                       class="flex items-center gap-2 px-4 py-2.5 bg-white rounded-xl text-green-700 hover:bg-green-50 text-sm font-semibold transition-all">
                        <span class="material-symbols-outlined text-lg">stars</span>
                        Hạnh kiểm
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Khu vực các lớp đang dạy -->
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-slate-800">Các lớp đang dạy</h2>
            @if (!string.IsNullOrEmpty(currentSemesterName))
            {
                <span class="text-sm text-slate-500">@currentSemesterName</span>
            }
        </div>

        @if (!teachingClasses.Any())
        {
            <div class="bg-white rounded-2xl border border-green-100 p-12 text-center">
                <span class="material-symbols-outlined text-5xl text-slate-300">school</span>
                <p class="mt-3 text-slate-500 font-medium">Chưa có lớp được phân công</p>
                <p class="text-sm text-slate-400 mt-1">Liên hệ quản trị viên để được phân công lớp dạy.</p>
            </div>
        }
        else
        {
            <!-- Lưới 2 cột -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                @{
                    var groupedByClass = teachingClasses
                        .GroupBy(tc => new { tc.ClassId, tc.ClassName, tc.GradeLevel })
                        .ToList();
                }

                @foreach (var group in groupedByClass)
                {
                    var firstItem = group.First();
                    <div class="bg-white rounded-xl border border-green-100 p-5 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-start justify-between mb-4">
                            <div>
                                <p class="text-lg font-bold text-slate-800">@group.Key.ClassName</p>
                                <p class="text-xs text-slate-500 mt-0.5">
                                    @(group.Key.GradeLevel > 0 ? "Khối " + group.Key.GradeLevel : "Chưa xếp khối")
                                </p>
                            </div>
                            <span class="inline-flex items-center px-2.5 py-0.5 bg-green-100 text-green-700 text-xs font-semibold rounded-full">
                                @group.Count() môn
                            </span>
                        </div>

                        <!-- Danh sách môn -->
                        <div class="space-y-2 mb-4">
                            @foreach (var item in group)
                            {
                                <div class="flex items-center justify-between py-1.5 border-b border-slate-50 last:border-0">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-base text-slate-400">book</span>
                                        <span class="text-sm text-slate-600">@item.SubjectName</span>
                                    </div>
                                    @if (item.PeriodsPerWeek.HasValue)
                                    {
                                        <span class="text-xs text-slate-400">@item.PeriodsPerWeek tiết/tuần</span>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Nút hành động -->
                        <div class="flex gap-2">
                            <a asp-controller="TeacherScore" asp-action="Index"
                               class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 bg-green-50 text-green-700 text-xs font-semibold rounded-lg hover:bg-green-100 transition-colors">
                                <span class="material-symbols-outlined text-base">grade</span>
                                Vào sổ điểm
                            </a>
                            <a asp-controller="TeacherAttendance" asp-action="Index"
                               class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 bg-blue-50 text-blue-700 text-xs font-semibold rounded-lg hover:bg-blue-100 transition-colors">
                                <span class="material-symbols-outlined text-base">how_to_reg</span>
                                Điểm danh
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>
