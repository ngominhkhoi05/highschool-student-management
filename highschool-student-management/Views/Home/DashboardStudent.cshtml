@using highschool_student_management.ViewModels
@{
    var isParentView = ViewBag.IsParentView ?? false;
    var parentName = (string)ViewBag.ParentName;
    var studentName = (string)ViewBag.StudentName;
    var schoolYearName = (string)ViewBag.SchoolYearName;
    var currentSemesterName = (string)ViewBag.CurrentSemesterName;
    var latestScores = (List<StudentScoreViewModel>)ViewBag.LatestScores;
    var avgScore = (decimal?)ViewBag.AvgScore;
    var attendanceStats = (StudentAttendanceSummary)ViewBag.AttendanceStats;

    var displayName = isParentView ? parentName : studentName;
}

<div class="p-6 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">
                Xin chào, @(isParentView ? parentName : studentName)
            </h1>
            <p class="text-sm text-slate-500 mt-1">
                @(schoolYearName)
                @(string.IsNullOrEmpty(currentSemesterName) ? "" : " - " + currentSemesterName)
            </p>
        </div>
    </div>

    <!-- Thông tin học sinh (nếu là phụ huynh) -->
    @if (isParentView)
    {
        var children = (List<ParentChildSummary>)ViewBag.Children;
        if (children.Any())
        {
            <div class="bg-white rounded-2xl border border-green-100 p-4 shadow-sm">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">
                    Xem thông tin của con
                </label>
                <select id="childSelector"
                        class="w-full px-4 py-2.5 border border-green-200 rounded-xl text-sm font-semibold text-green-700 bg-green-50 focus:ring-2 focus:ring-green-500/20 focus:border-green-400 cursor-pointer">
                    @foreach (var child in children)
                    {
                        <option value="@child.StudentId"
                                data-name="@child.FullName"
                                data-class="@child.ClassName">
                            @child.FullName (@child.StudentCode) - @child.ClassName
                        </option>
                    }
                </select>
            </div>
        }
    }

    <!-- Thông báo chưa có dữ liệu -->
    @if (string.IsNullOrEmpty(currentSemesterName))
    {
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
            <span class="material-symbols-outlined text-4xl text-amber-400">info</span>
            <p class="mt-2 font-medium text-amber-700">Chưa có dữ liệu học kỳ</p>
            <p class="text-sm text-amber-600 mt-1">Vui lòng liên hệ giáo viên để được cập nhật thông tin.</p>
        </div>
    }

    <!-- Cards: Điểm TB + Chấm dứt -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Điểm trung bình học kỳ -->
        <div class="bg-white rounded-2xl border border-green-100 shadow-sm overflow-hidden">
            <div class="bg-green-600 px-6 py-4">
                <h2 class="text-white font-bold text-base">Kết quả học tập</h2>
                @if (!string.IsNullOrEmpty(currentSemesterName))
                {
                    <p class="text-green-100 text-xs mt-0.5">@currentSemesterName</p>
                }
            </div>
            <div class="p-6">
                @if (avgScore.HasValue)
                {
                    var scoreValue = (double)avgScore.Value;
                    var displayValue = avgScore.Value.ToString("F2");
                    var progressPercent = Math.Min(scoreValue * 10, 100.0);
                    var scoreColor = scoreValue >= 8.0 ? "text-green-600" : scoreValue >= 6.5 ? "text-blue-600" : scoreValue >= 5.0 ? "text-amber-600" : "text-red-600";
                    var barColor = scoreValue >= 8.0 ? "bg-green-500" : scoreValue >= 6.5 ? "bg-blue-500" : scoreValue >= 5.0 ? "bg-amber-500" : "bg-red-500";
                    var scoreLabel = scoreValue >= 8.0 ? "Giỏi" : scoreValue >= 6.5 ? "Khá" : scoreValue >= 5.0 ? "Trung bình" : "Yếu";

                    <div class="text-center mb-4">
                        <p class="text-5xl font-bold @scoreColor">@displayValue</p>
                        <p class="text-sm text-slate-500 mt-1">Điểm trung bình học kỳ</p>
                        <span class="inline-flex items-center px-3 py-1 bg-@(scoreValue >= 8.0 ? "green" : scoreValue >= 6.5 ? "blue" : scoreValue >= 5.0 ? "amber" : "red")-100 text-@(scoreValue >= 8.0 ? "green" : scoreValue >= 6.5 ? "blue" : scoreValue >= 5.0 ? "amber" : "red")-700 text-xs font-bold rounded-full mt-2">
                            Xếp loại: @scoreLabel
                        </span>
                    </div>

                    <div class="mb-3">
                        <div class="flex justify-between text-xs text-slate-500 mb-1">
                            <span>0</span>
                            <span>Điểm TB</span>
                            <span>10</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                            <div class="@barColor h-full rounded-full transition-all duration-700"
                                 style="width: @progressPercent.ToString("F0")%"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-6 text-slate-400">
                        <span class="material-symbols-outlined text-4xl">grade</span>
                        <p class="mt-2 text-sm">Chưa có điểm trung bình</p>
                    </div>
                }
            </div>
        </div>

        <!-- Tóm tắt chuyên cần -->
        <div class="bg-white rounded-2xl border border-green-100 shadow-sm overflow-hidden">
            <div class="bg-blue-600 px-6 py-4">
                <h2 class="text-white font-bold text-base">Tóm tắt chuyên cần</h2>
                @if (!string.IsNullOrEmpty(currentSemesterName))
                {
                    <p class="text-blue-100 text-xs mt-0.5">@currentSemesterName</p>
                }
            </div>
            <div class="p-6">
                @if (attendanceStats != null && attendanceStats.TotalRecords > 0)
                {
                    var totalAbsences = attendanceStats.TotalAbsentPermit + attendanceStats.TotalAbsentNoPermit;
                    var attendanceRate = attendanceStats.TotalRecords > 0
                        ? (attendanceStats.TotalPresent * 100.0 / attendanceStats.TotalRecords)
                        : 0;

                    <div class="grid grid-cols-2 gap-3 mb-4">
                        <div class="text-center p-3 bg-green-50 rounded-xl">
                            <p class="text-2xl font-bold text-green-700">@attendanceStats.TotalPresent</p>
                            <p class="text-xs text-green-600 font-medium mt-1">Có mặt</p>
                        </div>
                        <div class="text-center p-3 bg-amber-50 rounded-xl">
                            <p class="text-2xl font-bold text-amber-700">@attendanceStats.TotalLate</p>
                            <p class="text-xs text-amber-600 font-medium mt-1">Đi trễ</p>
                        </div>
                        <div class="text-center p-3 bg-yellow-50 rounded-xl">
                            <p class="text-2xl font-bold text-yellow-700">@attendanceStats.TotalAbsentPermit</p>
                            <p class="text-xs text-yellow-600 font-medium mt-1">Vắng có phép</p>
                        </div>
                        <div class="text-center p-3 bg-red-50 rounded-xl">
                            <p class="text-2xl font-bold text-red-700">@attendanceStats.TotalAbsentNoPermit</p>
                            <p class="text-xs text-red-600 font-medium mt-1">Vắng không phép</p>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="flex justify-between text-xs text-slate-500 mb-1">
                            <span>Tỷ lệ điểm danh</span>
                            <span>@attendanceRate.ToString("F1")%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                            <div class="bg-blue-500 h-full rounded-full transition-all duration-700"
                                 style="width: @attendanceRate.ToString("F0")%"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-6 text-slate-400">
                        <span class="material-symbols-outlined text-4xl">how_to_reg</span>
                        <p class="mt-2 text-sm">Chưa có dữ liệu điểm danh</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Bảng điểm mới nhất -->
    <div class="bg-white rounded-2xl border border-green-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-green-100 flex items-center justify-between">
            <div>
                <h2 class="text-base font-bold text-slate-800">Kết quả học tập mới nhất</h2>
                @if (!string.IsNullOrEmpty(currentSemesterName))
                {
                    <p class="text-xs text-slate-500 mt-0.5">@currentSemesterName</p>
                }
            </div>
        </div>

        @if (!latestScores.Any())
        {
            <div class="text-center py-12 text-slate-400">
                <span class="material-symbols-outlined text-5xl">grade</span>
                <p class="mt-3 font-medium">Chưa có điểm nào</p>
                <p class="text-sm mt-1">Điểm sẽ được cập nhật sau khi giáo viên nhập điểm.</p>
            </div>
        }
        else
        {
            var groupedScores = latestScores
                .GroupBy(s => new { s.SubjectId, s.SubjectName })
                .ToList();

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-green-600 text-white">
                        <tr>
                            <th class="px-4 py-3 text-left font-semibold w-12">STT</th>
                            <th class="px-4 py-3 text-left font-semibold">Môn học</th>
                            <th class="px-4 py-3 text-center font-semibold">Loại điểm</th>
                            <th class="px-4 py-3 text-center font-semibold">Điểm</th>
                            <th class="px-4 py-3 text-center font-semibold">Ngày thi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var stt = 1; }
                        @foreach (var group in groupedScores)
                        {
                            @foreach (var score in group.OrderByDescending(s => s.ExamDate))
                            {
                                var scoreColorClass = score.ScoreValue.HasValue
                                    ? (double)score.ScoreValue.Value >= 8.0 ? "text-green-700 font-bold"
                                    : (double)score.ScoreValue.Value < 5.0 ? "text-red-600 font-bold"
                                    : "text-slate-700"
                                    : "text-slate-400";
                                <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-50/50 transition-colors">
                                    <td class="px-4 py-3 text-slate-400 text-xs">@stt</td>
                                    <td class="px-4 py-3 font-medium text-slate-800">@score.SubjectName</td>
                                    <td class="px-4 py-3 text-center text-slate-500">@score.ScoreTypeName</td>
                                    <td class="px-4 py-3 text-center @scoreColorClass">
                                        @(score.ScoreValue?.ToString("F1") ?? "-")
                                    </td>
                                    <td class="px-4 py-3 text-center text-slate-400 text-xs">
                                        @(score.ExamDate?.ToString("dd/MM/yyyy") ?? "-")
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
