@{
    var totalStudents = (int)ViewBag.TotalStudents;
    var totalTeachers = (int)ViewBag.TotalTeachers;
    var totalClasses = (int)ViewBag.TotalClasses;
    var totalUsers = (int)ViewBag.TotalUsers;
    var schoolYearName = (string)ViewBag.SchoolYearName;
    var studentByGrade = (List<highschool_student_management.ViewModels.GradeStatViewModel>)ViewBag.StudentByGrade;
}

<div class="p-6 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Bảng điều khiển</h1>
            <p class="text-sm text-slate-500 mt-1">Năm học: @schoolYearName</p>
        </div>
    </div>

    <!-- Cards thống kê tổng quan -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white border-l-4 border-green-500 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-3xl font-bold text-slate-800">@totalStudents</p>
                    <p class="text-sm font-medium text-slate-500 mt-1">Học sinh</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl text-green-600">groups</span>
                </div>
            </div>
            <a asp-controller="Student" asp-action="Index" class="block mt-3 text-xs text-green-600 font-medium hover:text-green-700">Xem chi tiết</a>
        </div>

        <div class="bg-white border-l-4 border-blue-500 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-3xl font-bold text-slate-800">@totalTeachers</p>
                    <p class="text-sm font-medium text-slate-500 mt-1">Giáo viên</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl text-blue-600">school</span>
                </div>
            </div>
            <a asp-controller="Teacher" asp-action="Index" class="block mt-3 text-xs text-blue-600 font-medium hover:text-blue-700">Xem chi tiết</a>
        </div>

        <div class="bg-white border-l-4 border-purple-500 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-3xl font-bold text-slate-800">@totalClasses</p>
                    <p class="text-sm font-medium text-slate-500 mt-1">Lớp học</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl text-purple-600">class</span>
                </div>
            </div>
            <a asp-controller="Class" asp-action="Index" class="block mt-3 text-xs text-purple-600 font-medium hover:text-purple-700">Xem chi tiết</a>
        </div>

        <div class="bg-white border-l-4 border-amber-500 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-3xl font-bold text-slate-800">@totalUsers</p>
                    <p class="text-sm font-medium text-slate-500 mt-1">Tài khoản</p>
                </div>
                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl text-amber-600">manage_accounts</span>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Index" class="block mt-3 text-xs text-amber-600 font-medium hover:text-amber-700">Xem chi tiết</a>
        </div>
    </div>

    <!-- Biểu đồ số học sinh theo khối lớp -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6">
            <h2 class="text-lg font-bold text-slate-800 mb-1">Số lượng học sinh theo khối lớp</h2>
            <p class="text-sm text-slate-500 mb-6">@schoolYearName</p>

            @if (!studentByGrade.Any() || studentByGrade.All(g => g.StudentCount == 0))
            {
                <div class="text-center py-12 text-slate-400">
                    <span class="material-symbols-outlined text-5xl">analytics</span>
                    <p class="mt-3 font-medium">Chưa có dữ liệu phân bổ học sinh</p>
                    <p class="text-sm mt-1">Vui lòng đảm bảo đã có dữ liệu phân lớp học sinh.</p>
                </div>
            }
            else
            {
                <div class="relative">
                    <canvas id="gradeChart" height="240"></canvas>
                </div>
            }
        </div>

        <!-- Thống kê nhanh -->
        <div class="space-y-4">
            <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Truy cập nhanh</h2>
                <div class="grid grid-cols-2 gap-3">
                    <a asp-controller="SchoolYear" asp-action="Index" class="flex items-center gap-3 px-4 py-3 bg-green-50 rounded-xl hover:bg-green-100 transition-colors">
                        <span class="material-symbols-outlined text-xl text-green-600">calendar_today</span>
                        <span class="text-sm font-medium text-slate-700">Năm học</span>
                    </a>
                    <a asp-controller="Subject" asp-action="Index" class="flex items-center gap-3 px-4 py-3 bg-blue-50 rounded-xl hover:bg-blue-100 transition-colors">
                        <span class="material-symbols-outlined text-xl text-blue-600">book</span>
                        <span class="text-sm font-medium text-slate-700">Môn học</span>
                    </a>
                    <a asp-controller="ScoreType" asp-action="Index" class="flex items-center gap-3 px-4 py-3 bg-purple-50 rounded-xl hover:bg-purple-100 transition-colors">
                        <span class="material-symbols-outlined text-xl text-purple-600">score</span>
                        <span class="text-sm font-medium text-slate-700">Loại điểm</span>
                    </a>
                    <a asp-controller="ViolationType" asp-action="Index" class="flex items-center gap-3 px-4 py-3 bg-red-50 rounded-xl hover:bg-red-100 transition-colors">
                        <span class="material-symbols-outlined text-xl text-red-600">gavel</span>
                        <span class="text-sm font-medium text-slate-700">Loại vi phạm</span>
                    </a>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6">
                <h2 class="text-lg font-bold text-slate-800 mb-4">Thống kê đơn giản</h2>
                <div class="space-y-3">
                    <div class="flex items-center justify-between py-2 border-b border-slate-100">
                        <span class="text-sm text-slate-600">Tổng học sinh</span>
                        <span class="font-bold text-green-700">@totalStudents</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-b border-slate-100">
                        <span class="text-sm text-slate-600">Tổng giáo viên</span>
                        <span class="font-bold text-blue-700">@totalTeachers</span>
                    </div>
                    <div class="flex items-center justify-between py-2 border-b border-slate-100">
                        <span class="text-sm text-slate-600">Tổng lớp học</span>
                        <span class="font-bold text-purple-700">@totalClasses</span>
                    </div>
                    <div class="flex items-center justify-between py-2">
                        <span class="text-sm text-slate-600">Tỷ lệ GV/Học sinh</span>
                        <span class="font-bold text-slate-700">
                            @(totalStudents > 0 ? (totalTeachers * 1.0 / totalStudents * 100).ToString("F1") + "%" : "N/A")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var gradeData = @Html.Raw(Json.Serialize(studentByGrade));
            if (!gradeData || gradeData.length === 0 || gradeData.every(function(g) { return g.studentCount === 0; })) return;

            var labels = gradeData.map(function(g) {
                if (g.gradeLevel === 0) return 'Khác';
                return 'Khối ' + g.gradeLevel;
            });
            var data = gradeData.map(function(g) { return g.studentCount; });

            var ctx = document.getElementById('gradeChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Số lượng HS',
                        data: data,
                        backgroundColor: [
                            'rgba(34, 197, 94, 0.75)',
                            'rgba(59, 130, 246, 0.75)',
                            'rgba(139, 92, 246, 0.75)',
                            'rgba(249, 115, 22, 0.75)',
                            'rgba(239, 68, 68, 0.75)'
                        ],
                        borderColor: [
                            'rgb(34, 197, 94)',
                            'rgb(59, 130, 246)',
                            'rgb(139, 92, 246)',
                            'rgb(249, 115, 22)',
                            'rgb(239, 68, 68)'
                        ],
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.parsed.y + ' học sinh';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1,
                                font: { family: 'Lexend' }
                            },
                            grid: {
                                color: 'rgba(0,0,0,0.05)'
                            }
                        },
                        x: {
                            ticks: { font: { family: 'Lexend', size: 12 } },
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
