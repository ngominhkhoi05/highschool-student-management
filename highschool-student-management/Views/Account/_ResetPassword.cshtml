@model highschool_student_management.ViewModels.ResetPasswordViewModel

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold text-lg">Dat lai mat khau</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formResetPassword" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="UserId" value="@Model.UserId" />

        <!-- Thong tin tai khoan -->
        <div class="bg-green-50 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 bg-green-600 text-white rounded-full flex items-center justify-center text-sm font-bold">
                @Model.Username[0].ToString().ToUpper()
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-800">@Model.Username</p>
                <p class="text-xs text-slate-500">Tai khoan can dat lai mat khau</p>
            </div>
        </div>

        <!-- Mat khau moi -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Mat khau moi <span class="text-red-500">*</span>
            </label>
            <input type="password"
                   name="NewPassword"
                   id="newPassword"
                   placeholder="Nhap mat khau moi (toi thieu 6 ky tu)"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
        </div>

        <!-- Xac nhan mat khau -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Xac nhan mat khau <span class="text-red-500">*</span>
            </label>
            <input type="password"
                   name="ConfirmPassword"
                   id="confirmPassword"
                   placeholder="Nhap lai mat khau moi"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bo
            </button>
            <button type="button"
                    onclick="submitResetPassword()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                Dat lai mat khau
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitResetPassword() {
        var newPass = $('#newPassword').val();
        var confirmPass = $('#confirmPassword').val();

        if (!newPass || !newPass.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Loi',
                text: 'Mat khau moi khong duoc de trong.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        if (newPass.length < 6) {
            Swal.fire({
                icon: 'error',
                title: 'Loi',
                text: 'Mat khau moi phai tu 6 ky tu tro len.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        if (newPass !== confirmPass) {
            Swal.fire({
                icon: 'error',
                title: 'Loi',
                text: 'Mat khau xac nhan khong khop.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var formData = $('#formResetPassword').serialize();

        $.ajax({
            url: '@Url.Action("ResetPassword", "Account")',
            type: 'POST',
            data: formData,
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thanh cong!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Loi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Loi',
                    text: 'Khong the dat lai mat khau. Vui long thu lai.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
