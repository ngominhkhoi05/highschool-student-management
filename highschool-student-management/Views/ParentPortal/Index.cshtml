@model highschool_student_management.ViewModels.ParentPortalViewModel

@{
    ViewData["Title"] = "Tra cứu";
}

<div class="p-6 space-y-6">

    <!-- Chon con ( noi bat) -->
    @if (Model.Children.Any())
    {
        <div class="bg-white rounded-2xl border border-green-200 p-4">
            <label class="block text-sm font-semibold text-slate-600 mb-2">
                <span class="material-symbols-outlined text-base align-middle">family_restroom</span>
                Xem thông tin của con
            </label>
            <select id="childSelector" onchange="changeChild()"
                    class="w-full px-4 py-3 border-2 border-green-300 rounded-xl text-base font-semibold text-green-700 bg-green-50 focus:ring-2 focus:ring-green-500/20 focus:border-green-400 cursor-pointer">
                @foreach (var child in Model.Children)
                {
                    <option value="@child.StudentId" selected="@(child.StudentId == Model.SelectedStudentId)">
                        @child.FullName (@child.StudentCode)
                    </option>
                }
            </select>
        </div>
    }

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-green-100 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-green-600">school</span>
            </div>
            <div>
                <h1 class="text-xl font-bold text-slate-800">Tra cứu thông tin</h1>
                <p class="text-sm text-slate-500">@Model.ParentName</p>
            </div>
        </div>
    </div>

    <!-- Menu tra cuu -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a asp-action="Scores" asp-route-studentId="@Model.SelectedStudentId"
           class="bg-white rounded-2xl border border-green-100 p-6 hover:shadow-md hover:border-green-300 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center text-white group-hover:bg-green-600 transition-colors">
                    <span class="material-symbols-outlined text-2xl">grade</span>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Bảng điểm</h3>
                    <p class="text-sm text-slate-500">Xem điểm theo học kỳ</p>
                </div>
            </div>
        </a>

        <a asp-action="Attendances" asp-route-studentId="@Model.SelectedStudentId"
           class="bg-white rounded-2xl border border-green-100 p-6 hover:shadow-md hover:border-green-300 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center text-white group-hover:bg-blue-600 transition-colors">
                    <span class="material-symbols-outlined text-2xl">how_to_reg</span>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Điểm danh</h3>
                    <p class="text-sm text-slate-500">Xem tình trạng điểm danh</p>
                </div>
            </div>
        </a>

        <a asp-action="Conduct" asp-route-studentId="@Model.SelectedStudentId"
           class="bg-white rounded-2xl border border-green-100 p-6 hover:shadow-md hover:border-green-300 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-purple-500 rounded-xl flex items-center justify-center text-white group-hover:bg-purple-600 transition-colors">
                    <span class="material-symbols-outlined text-2xl">stars</span>
                </div>
                <div>
                    <h3 class="font-bold text-slate-800">Hạnh kiểm</h3>
                    <p class="text-sm text-slate-500">Xem điểm hạnh kiểm và vi phạm</p>
                </div>
            </div>
        </a>
    </div>

</div>

@section Scripts {
    <script>
        function changeChild() {
            var studentId = document.getElementById('childSelector').value;
            window.location.href = '@Url.Action("Index", "ParentPortal")' + '?studentId=' + studentId;
        }
    </script>
}
