@model highschool_student_management.ViewModels.ParentAttendancesViewModel

@{
    ViewData["Title"] = "Diem danh";
}

<div class="p-6 space-y-6">

    <!-- Chon con -->
    @if (Model.Children.Any())
    {
        <div class="bg-white rounded-2xl border border-green-200 p-4">
            <label class="block text-sm font-semibold text-slate-600 mb-2">
                <span class="material-symbols-outlined text-base align-middle">family_restroom</span>
                Xem thong tin cua con
            </label>
            <select id="childSelector" onchange="changeChild()"
                    class="w-full px-4 py-3 border-2 border-green-300 rounded-xl text-base font-semibold text-green-700 bg-green-50 focus:ring-2 focus:ring-green-500/20 focus:border-green-400 cursor-pointer">
                @foreach (var child in Model.Children)
                {
                    <option value="@child.StudentId" selected="@(child.StudentId == Model.SelectedStudentId)">
                        @child.FullName (@child.StudentCode)
                    </option>
                }
            </select>
        </div>
    }

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-blue-600">how_to_reg</span>
            <div>
                <h1 class="text-xl font-bold text-slate-800">Diem danh</h1>
                <p class="text-sm text-slate-500">@Model.FullName (@Model.StudentCode)</p>
            </div>
        </div>
        <a asp-action="Index" class="text-sm text-green-600 hover:text-green-700 font-medium">Quay lai</a>
    </div>

    <!-- Chon hoc ky -->
    <div class="flex flex-wrap gap-2">
        @foreach (var sem in Model.Semesters)
        {
            <a asp-action="Attendances" asp-route-studentId="@Model.SelectedStudentId" asp-route-semesterId="@sem.Id"
               class="px-4 py-2 rounded-lg text-sm font-medium transition-all
                      @(sem.Id == Model.CurrentSemesterId ? "bg-green-600 text-white" : "bg-green-50 text-green-700 hover:bg-green-100")">
                @sem.Name
            </a>
        }
    </div>

    <!-- Bang diem danh -->
    @if (!Model.Attendances.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300">how_to_reg</span>
            <p class="mt-3 text-slate-500 font-medium">Chua co du lieu diem danh</p>
        </div>
    }
    else
    {
        var present = Model.Attendances.Count(a => a.Status == 1);
        var absentPermit = Model.Attendances.Count(a => a.Status == 2);
        var absentNoPermit = Model.Attendances.Count(a => a.Status == 3);
        var late = Model.Attendances.Count(a => a.Status == 4);

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-green-700">@present</p>
                <p class="text-xs text-green-600 font-medium">Co mat</p>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-yellow-700">@absentPermit</p>
                <p class="text-xs text-yellow-600 font-medium">Vang co phep</p>
            </div>
            <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-red-700">@absentNoPermit</p>
                <p class="text-xs text-red-600 font-medium">Vang khong phep</p>
            </div>
            <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 text-center">
                <p class="text-2xl font-bold text-orange-700">@late</p>
                <p class="text-xs text-orange-600 font-medium">Di tre</p>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-green-600 text-white">
                            <th class="px-4 py-3 text-left font-semibold">Ngay</th>
                            <th class="px-4 py-3 text-center font-semibold">Tiet</th>
                            <th class="px-4 py-3 text-center font-semibold">Trang thai</th>
                            <th class="px-4 py-3 text-left font-semibold">Ghi chu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var i = 1; }
                        @foreach (var att in Model.Attendances)
                        {
                            var rowClass = i % 2 == 0 ? "bg-green-50" : "bg-white";
                            <tr class="@rowClass hover:bg-green-100 transition-colors">
                                <td class="px-4 py-3 text-slate-700">@att.Date.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-3 text-center text-slate-600">@(att.Period != null ? "Tiet " + att.Period : "Ca ngay")</td>
                                <td class="px-4 py-3 text-center">
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold @att.StatusClass">@att.StatusName</span>
                                </td>
                                <td class="px-4 py-3 text-slate-500">@(att.Note ?? "-")</td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeChild() {
            var studentId = document.getElementById('childSelector').value;
            window.location.href = '@Url.Action("Attendances", "ParentPortal")' + '?studentId=' + studentId + '&semesterId=@Model.CurrentSemesterId';
        }
    </script>
}
