@model highschool_student_management.ViewModels.ParentConductViewModel

@{
    ViewData["Title"] = "Hạnh kiểm";
}

<div class="p-6 space-y-6">

    <!-- Chọn con -->
    @if (Model.Children.Any())
    {
        <div class="bg-white rounded-2xl border border-green-200 p-4">
            <label class="block text-sm font-semibold text-slate-600 mb-2">
                <span class="material-symbols-outlined text-base align-middle">family_restroom</span>
                Xem thông tin của con
            </label>
            <select id="childSelector" onchange="changeChild()"
                    class="w-full px-4 py-3 border-2 border-green-300 rounded-xl text-base font-semibold text-green-700 bg-green-50 focus:ring-2 focus:ring-green-500/20 focus:border-green-400 cursor-pointer">
                @foreach (var child in Model.Children)
                {
                    <option value="@child.StudentId" selected="@(child.StudentId == Model.SelectedStudentId)">
                        @child.FullName (@child.StudentCode)
                    </option>
                }
            </select>
        </div>
    }

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-purple-600">stars</span>
            <div>
                <h1 class="text-xl font-bold text-slate-800">Hạnh kiểm và vi phạm</h1>
                <p class="text-sm text-slate-500">@Model.FullName (@Model.StudentCode)</p>
            </div>
        </div>
        <a asp-action="Index" class="text-sm text-green-600 hover:text-green-700 font-medium">Quay lai</a>
    </div>

    <!-- Chọn học kỳ -->
    <div class="flex flex-wrap gap-2">
        @foreach (var sem in Model.Semesters)
        {
            <a asp-action="Conduct" asp-route-studentId="@Model.SelectedStudentId" asp-route-semesterId="@sem.Id"
               class="px-4 py-2 rounded-lg text-sm font-medium transition-all
                      @(sem.Id == Model.CurrentSemesterId ? "bg-green-600 text-white" : "bg-green-50 text-green-700 hover:bg-green-100")">
                @sem.Name
            </a>
        }
    </div>

    <!-- Diem hanh kiem -->
    @if (Model.ConductScore != null)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6">
            <h2 class="text-lg font-bold text-slate-800 mb-4">Xếp loại hạnh kiểm</h2>
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center @Model.ConductScore.RankClass text-xl font-bold">
                    @(Model.ConductScore.ConductRank > 0 ? Model.ConductScore.RankName : "-")
                </div>
                <div>
                    <p class="font-bold text-slate-700">@(Model.ConductScore.RankName)</p>
                    <p class="text-sm text-slate-500">
                        Điểm tích lũy: @(Model.ConductScore.Score?.ToString() ?? "Chưa có")
                    </p>
                    @if (!string.IsNullOrEmpty(Model.ConductScore.Note))
                    {
                        <p class="text-sm text-slate-500 mt-1">Ghi chú: @Model.ConductScore.Note</p>
                    }
                    @if (Model.ConductScore.EvaluatedAt.HasValue)
                    {
                        <p class="text-xs text-slate-400 mt-1">Đánh giá lần cuối: @Model.ConductScore.EvaluatedAt.Value.ToString("dd/MM/yyyy")</p>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6 text-center">
            <span class="material-symbols-outlined text-4xl text-slate-300">stars</span>
            <p class="mt-2 text-slate-500">Chưa có dữ liệu đánh giá hạnh kiểm</p>
        </div>
    }

    <!-- Bang vi pham -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-green-100">
            <h2 class="text-lg font-bold text-slate-800">Lịch sử vi phạm</h2>
        </div>
        @if (!Model.Violations.Any())
        {
            <div class="p-12 text-center">
                <span class="material-symbols-outlined text-5xl text-green-300">check_circle</span>
                <p class="mt-3 text-slate-500 font-medium">Không có vi phạm nào</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-red-50 text-red-700">
                            <th class="px-4 py-3 text-left font-semibold">Ngày</th>
                            <th class="px-4 py-3 text-left font-semibold">Loại vi phạm</th>
                            <th class="px-4 py-3 text-center font-semibold">Mức độ</th>
                            <th class="px-4 py-3 text-left font-semibold">Mô tả</th>
                            <th class="px-4 py-3 text-center font-semibold">Xử lý</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var j = 1; }
                        @foreach (var v in Model.Violations)
                        {
                            var rowClass = j % 2 == 0 ? "bg-red-50/50" : "bg-white";
                            <tr class="@rowClass">
                                <td class="px-4 py-3 text-slate-700">@v.ViolationDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-3 font-medium text-slate-700">@v.ViolationTypeName</td>
                                <td class="px-4 py-3 text-center">
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold @v.SeverityClass">
                                        @(v.Severity == 1 ? "Nhẹ" : v.Severity == 2 ? "Trung bình" : "Nặng")
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-slate-500">@(v.Description ?? "-")</td>
                                <td class="px-4 py-3 text-center text-slate-600">@v.ActionName</td>
                            </tr>
                            j++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function changeChild() {
            var studentId = document.getElementById('childSelector').value;
            window.location.href = '@Url.Action("Conduct", "ParentPortal")' + '?studentId=' + studentId + '&semesterId=@Model.CurrentSemesterId';
        }
    </script>
}
