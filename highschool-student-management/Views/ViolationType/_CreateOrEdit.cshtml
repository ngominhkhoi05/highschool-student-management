@model QuanLyHocSinh.Models.ViolationType

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa loại vi phạm" : "Thêm loại vi phạm mới";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formViolationType" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <!-- Tên loại vi phạm -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Tên loại vi phạm <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="Name"
                   id="vtName"
                   value="@Model.Name"
                   placeholder="VD: Đi trễ"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
        </div>

        <!-- Mức độ -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Mức độ
            </label>
            <select name="Severity"
                    class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                <option value="">-- Chọn mức độ --</option>
                @if (Model.Severity == 1)
                {
                    <option value="1" selected>1 - Nhẹ</option>
                }
                else
                {
                    <option value="1">1 - Nhẹ</option>
                }
                @if (Model.Severity == 2)
                {
                    <option value="2" selected>2 - Trung bình</option>
                }
                else
                {
                    <option value="2">2 - Trung bình</option>
                }
                @if (Model.Severity == 3)
                {
                    <option value="3" selected>3 - Nặng</option>
                }
                else
                {
                    <option value="3">3 - Nặng</option>
                }
            </select>
        </div>

        <!-- Điểm trừ -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Điểm trừ hạnh kiểm <span class="text-red-500">*</span>
            </label>
            <input type="number"
                   name="DeductPoints"
                   id="vtDeductPoints"
                   value="@Model.DeductPoints"
                   placeholder="VD: 1"
                   min="0"
                   max="10"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
            <p class="text-xs text-slate-400 mt-1">Số điểm trừ vào hạnh kiểm khi vi phạm</p>
        </div>

        <!-- Mô tả -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Mô tả chi tiết
            </label>
            <textarea name="Description"
                      id="vtDescription"
                      rows="3"
                      placeholder="Mô tả chi tiết về loại vi phạm này..."
                      class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300 resize-none">@Model.Description</textarea>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Hủy bỏ
            </button>
            <button type="button"
                    onclick="submitViolationTypeForm()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Thêm loại vi phạm")
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitViolationTypeForm() {
        var name = $('#vtName').val();

        if (!name || !name.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Tên loại vi phạm không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var formData = $('#formViolationType').serialize();

        $.ajax({
            url: '@Url.Action("SaveViolationType", "ViolationType")',
            type: 'POST',
            data: formData,
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
