@model List<QuanLyHocSinh.Models.Subject>

@{
    ViewData["Title"] = "Quản lý môn học";
}

<div class="max-w-5xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Quản lý môn học</h1>
            <p class="text-sm text-slate-500 mt-1">Thêm, sửa, xóa môn học trong hệ thống</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 rounded-xl font-semibold text-sm shadow-sm transition-all duration-200 active:scale-95"
                data-url="@Url.Action("_CreateOrEdit", "Subject", new { id = 0 })"
                data-title="Thêm môn học mới">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm môn học
        </button>
    </div>

    <!-- Bang danh sach Mon hoc -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-6 py-4 text-left font-semibold w-10">#</th>
                    <th class="px-4 py-4 text-left font-semibold">Tên môn học</th>
                    <th class="px-4 py-4 text-left font-semibold">Mã môn</th>
                    <th class="px-4 py-4 text-center font-semibold">Khối lớp</th>
                    <th class="px-4 py-4 text-center font-semibold">Số tiết/tuần</th>
                    <th class="px-4 py-4 text-center font-semibold">Trạng thái</th>
                    <th class="px-4 py-4 text-center font-semibold w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">search_off</span>
                            <p class="mt-2">Chưa có môn học nào. Nhấn "Thêm môn học" để bắt đầu.</p>
                        </td>
                    </tr>
                }
                else
                {
                    var index = 1;
                    foreach (var subject in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50 hover:bg-green-100/40 transition-colors">
                            <td class="px-6 py-3.5 text-slate-400 text-xs font-medium">@index</td>
                            <td class="px-4 py-3.5 font-medium text-slate-800">@subject.Name</td>
                            <td class="px-4 py-3.5">
                                <span class="inline-flex items-center px-2 py-0.5 bg-slate-100 text-slate-600 text-xs font-mono font-semibold rounded">@subject.Code</span>
                            </td>
                            <td class="px-4 py-3.5 text-center text-slate-600">
                                @(subject.GradeLevel.HasValue ? $"Khối {subject.GradeLevel}" : "Tất cả khối")
                            </td>
                            <td class="px-4 py-3.5 text-center text-slate-600">
                                @(subject.PeriodsPerWeek.HasValue ? subject.PeriodsPerWeek : "-")
                            </td>
                            <td class="px-4 py-3.5 text-center">
                                @if (subject.IsActive == 1)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 text-green-700 text-xs font-semibold rounded-full">
                                        Đang dạy
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 text-slate-500 text-xs font-semibold rounded-full">
                                        Ngừng
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-all btn-render-modal"
                                            title="Sửa môn học"
                                            data-url="@Url.Action("_CreateOrEdit", "Subject", new { id = subject.Id })"
                                            data-title="Sửa môn học">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xóa môn học"
                                            onclick="deleteSubject(@subject.Id, '@subject.Name')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteSubject(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa môn học',
                text: 'Bạn có chắc chắn muốn xóa môn học "' + name + '"? Hành động này không thể hoàn tác.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteSubject", "Subject")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                }).then(function() {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Loi',
                                text: 'Không thể xóa môn học. Vui lòng thử lại.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
