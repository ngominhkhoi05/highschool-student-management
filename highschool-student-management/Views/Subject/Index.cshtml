@model List<QuanLyHocSinh.Models.Subject>

@{
    ViewData["Title"] = "Quản lý môn học";
}

<div class="max-w-5xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Quản lý môn học</h1>
            <p class="text-sm text-slate-500 mt-1">Thêm, sửa, xóa môn học trong hệ thống</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 rounded-xl font-semibold text-sm shadow-sm transition-all duration-200 active:scale-95"
                data-url="@Url.Action("_CreateOrEdit", "Subject", new { id = 0 })"
                data-title="Thêm môn học mới">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm môn học
        </button>
    </div>

    <!-- Bang danh sach Mon hoc -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <div class="relative flex-1 max-w-md">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                <input type="text"
                       id="searchInput"
                       value="@ViewData["Search"]"
                       placeholder="Tìm kiếm theo tên hoặc mã môn học..."
                       class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
            <span id="searchCount" class="text-sm text-slate-400 whitespace-nowrap"></span>
            @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
            {
                <a id="btnClearFilter" asp-action="Index" class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">Xóa lọc</a>
            }
            else
            {
                <span id="btnClearFilter" class="hidden px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all cursor-pointer">Xóa lọc</span>
            }
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-6 py-4 text-left font-semibold w-10">#</th>
                    <th class="px-4 py-4 text-left font-semibold">Tên môn học</th>
                    <th class="px-4 py-4 text-left font-semibold">Mã môn</th>
                    <th class="px-4 py-4 text-center font-semibold">Khối lớp</th>
                    <th class="px-4 py-4 text-center font-semibold">Số tiết/tuần</th>
                    <th class="px-4 py-4 text-center font-semibold">Trạng thái</th>
                    <th class="px-4 py-4 text-center font-semibold w-32">Thao tác</th>
                </tr>
            </thead>
            <tbody id="subjectTableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">search_off</span>
                            <p class="mt-2">Không có môn học nào phù hợp.</p>
                        </td>
                    </tr>
                }
                else
                {
                    var index = 1;
                    foreach (var subject in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50 hover:bg-green-100/40 transition-colors">
                            <td class="px-6 py-3.5 text-slate-400 text-xs font-medium">@index</td>
                            <td class="px-4 py-3.5 font-medium text-slate-800">@subject.Name</td>
                            <td class="px-4 py-3.5">
                                <span class="inline-flex items-center px-2 py-0.5 bg-slate-100 text-slate-600 text-xs font-mono font-semibold rounded">@subject.Code</span>
                            </td>
                            <td class="px-4 py-3.5 text-center text-slate-600">
                                @(subject.GradeLevel.HasValue ? $"Khối {subject.GradeLevel}" : "Tất cả khối")
                            </td>
                            <td class="px-4 py-3.5 text-center text-slate-600">
                                @(subject.PeriodsPerWeek.HasValue ? subject.PeriodsPerWeek.ToString() : "-")
                            </td>
                            <td class="px-4 py-3.5 text-center">
                                @if (subject.IsActive == 1)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 text-green-700 text-xs font-semibold rounded-full">Đang dạy</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 text-slate-500 text-xs font-semibold rounded-full">Ngừng</span>
                                }
                            </td>
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-all btn-render-modal"
                                            title="Sửa môn học"
                                            data-url="@Url.Action("_CreateOrEdit", "Subject", new { id = subject.Id })"
                                            data-title="Sửa môn học">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xóa môn học"
                                            onclick="deleteSubject(@subject.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(subject.Name))')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        var searchTimer = null;

        function reloadTable(searchValue) {
            $.ajax({
                url: '@Url.Action("Index", "Subject")',
                type: 'GET',
                data: { search: searchValue },
                success: function(html) {
                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');
                    var newBody = doc.querySelector('#subjectTableBody');
                    if (newBody) {
                        $('#subjectTableBody').html(newBody.innerHTML);
                    }
                },
                error: function() {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể tải dữ liệu.', confirmButtonColor: '#006b2c' });
                }
            });
        }

        function updateSearchUI(count, searchValue) {
            var countEl = $('#searchCount');
            if (searchValue && searchValue.length > 0) {
                countEl.text(count + ' kết quả');
                $('#btnClearFilter').removeClass('hidden').addClass('inline-flex items-center gap-2');
                $('#btnClearFilter').html('<span class="material-symbols-outlined text-base">close</span> Xóa lọc');
                $('#btnClearFilter').unbind('click').on('click', function() {
                    $('#searchInput').val('');
                    reloadTable('');
                });
            } else {
                countEl.text('');
                $('#btnClearFilter').addClass('hidden').removeClass('inline-flex items-center gap-2');
            }
        }

        $(document).ready(function() {
            var initialCount = @Model.Count();
            updateSearchUI(initialCount, '@ViewData["Search"]');

            $('#searchInput').on('input', function() {
                var value = $(this).val();
                clearTimeout(searchTimer);
                searchTimer = setTimeout(function() {
                    reloadTable(value);
                    updateSearchUI($('#subjectTableBody tr').length, value);
                }, 350);
            });
        });

        function deleteSubject(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa môn học',
                text: 'Bạn có chắc chắn muốn xóa môn học "' + name + '"? Hành động này không thể hoàn tác.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteSubject", "Subject")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({ icon: 'success', title: 'Thành công!', text: result.message, confirmButtonColor: '#006b2c' }).then(function() {
                                    var currentSearch = $('#searchInput').val();
                                    reloadTable(currentSearch);
                                    updateSearchUI($('#subjectTableBody tr').length, currentSearch);
                                });
                            } else {
                                Swal.fire({ icon: 'error', title: 'Lỗi', text: result.message, confirmButtonColor: '#006b2c' });
                            }
                        },
                        error: function() {
                            Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể xóa môn học.', confirmButtonColor: '#006b2c' });
                        }
                    });
                }
            });
        }
    </script>
}
