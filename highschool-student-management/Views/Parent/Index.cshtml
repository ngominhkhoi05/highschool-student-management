@model List<highschool_student_management.ViewModels.ParentIndexViewModel>

@{
    ViewData["Title"] = "Phụ huynh";
}

<div class="max-w-6xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Phụ huynh</h1>
            <p class="text-sm text-slate-500 mt-1">Quản lý danh sách phụ huynh</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm"
                data-url="@Url.Action("_CreateOrEdit", "Parent", new { id = 0 })"
                data-title="Thêm phụ huynh mới">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm phụ huynh
        </button>
    </div>

    <!-- Bang danh sach -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <form method="get" class="flex-1 flex items-center gap-3">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input type="text"
                           name="search"
                           value="@ViewData["Search"]"
                           placeholder="Tìm kiếm theo tên hoặc số điện thoại..."
                           class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                </div>
                <button type="submit"
                        class="px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm">
                    Tìm kiếm
                </button>
                @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                {
                    <a asp-action="Index"
                       class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">
                        Xóa lọc
                    </a>
                }
            </form>
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-4 py-4 text-left font-semibold w-12">#</th>
                    <th class="px-4 py-4 text-left font-semibold">Họ và tên</th>
                    <th class="px-4 py-4 text-left font-semibold">Quan hệ</th>
                    <th class="px-4 py-4 text-left font-semibold">Số điện thoại</th>
                    <th class="px-4 py-4 text-left font-semibold">Nghề nghiệp</th>
                    <th class="px-4 py-4 text-left font-semibold">Học sinh được gán</th>
                    <th class="px-4 py-4 text-center font-semibold w-44">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">family_restroom</span>
                            <p class="mt-2">Chưa có phụ huynh nào.</p>
                        </td>
                    </tr>
                }
                else
                {
                    var idx = 1;
                    foreach (var parent in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors">
                            <td class="px-4 py-3 text-slate-400 text-xs font-medium">@idx</td>
                            <td class="px-4 py-3">
                                <p class="font-semibold text-slate-800">@parent.FullName</p>
                                <p class="text-xs text-slate-400">@parent.Email</p>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@parent.RelationshipName</td>
                            <td class="px-4 py-3 text-slate-600">@parent.Phone</td>
                            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(parent.Occupation) ? "-" : parent.Occupation)</td>
                            <td class="px-4 py-3">
                                @if (parent.AssignedStudentNames.Any())
                                {
                                    <div class="flex flex-wrap gap-1">
                                        @foreach (var name in parent.AssignedStudentNames.Take(3))
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 bg-blue-50 text-blue-600 text-xs font-medium rounded-full">
                                                @name
                                            </span>
                                        }
                                        @if (parent.AssignedStudentNames.Count > 3)
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 bg-slate-100 text-slate-500 text-xs font-medium rounded-full">
                                                +@(parent.AssignedStudentNames.Count - 3)
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-slate-400 text-xs">Chưa gán</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-purple-600 hover:bg-purple-50 rounded-lg transition-all btn-render-modal"
                                            title="Gán học sinh"
                                            data-url="@Url.Action("_AssignStudents", "Parent", new { parentId = parent.Id })"
                                            data-title="Gán học sinh cho phụ huynh">
                                        <span class="material-symbols-outlined text-base">manage_accounts</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                                            title="Sửa"
                                            data-url="@Url.Action("_CreateOrEdit", "Parent", new { id = parent.Id })"
                                            data-title="Sửa phụ huynh">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xóa"
                                            onclick="deleteParent(@parent.Id, '@parent.FullName')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        idx++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteParent(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa',
                text: 'Bạn có muốn xóa phụ huynh "' + name + '" không? Hành động này sẽ xóa cả tài khoản liên quan.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Parent")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                }).then(function() {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: 'Không thể xóa. Vui lòng thử lại.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
