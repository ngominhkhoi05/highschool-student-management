@model highschool_student_management.ViewModels.AssignStudentsViewModel

<div class="bg-white rounded-2xl shadow-xl w-full max-w-lg mx-auto overflow-hidden max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <h3 class="text-white font-bold text-lg">Gan hoc sinh</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formAssignStudents" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="parentId" value="@Model.ParentId" />

        <!-- Thong tin phu huynh -->
        <div class="bg-green-50 rounded-xl p-4 flex items-center gap-3">
            <div class="w-10 h-10 bg-green-600 text-white rounded-full flex items-center justify-center text-sm font-bold">
                @Model.ParentName[0].ToString().ToUpper()
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-800">@Model.ParentName</p>
                <p class="text-xs text-slate-500">Chon hoc sinh de gan cho phu huynh nay</p>
            </div>
        </div>

        <!-- Danh sach hoc sinh -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2">
                Danh sach hoc sinh <span class="text-red-500">*</span>
            </label>
            <select name="studentIds"
                    id="studentSelect"
                    multiple
                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white min-h-[200px]">
                @foreach (var student in Model.AllStudents)
                {
                    if (student.IsSelected)
                    {
                        <option value="@student.Id" selected>
                            @student.StudentCode - @student.FullName
                        </option>
                    }
                    else
                    {
                        <option value="@student.Id">
                            @student.StudentCode - @student.FullName
                        </option>
                    }
                }
            </select>
            <p class="text-xs text-slate-400 mt-1">Giu phim Ctrl de chon nhieu hoc sinh</p>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bo
            </button>
            <button type="button"
                    onclick="submitAssignStudents()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                Luu phan gan
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitAssignStudents() {
        var selectedIds = [];
        $('#studentSelect option:selected').each(function() {
            selectedIds.push(parseInt($(this).val()));
        });

        $.ajax({
            url: '@Url.Action("SaveAssignedStudents", "Parent")',
            type: 'POST',
            data: {
                parentId: '@Model.ParentId',
                studentIds: selectedIds,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thanh cong!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Loi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Loi',
                    text: 'Khong the luu. Vui long thu lai.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
