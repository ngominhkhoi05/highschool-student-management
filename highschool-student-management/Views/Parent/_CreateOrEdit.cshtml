@model highschool_student_management.ViewModels.ParentFormViewModel

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa phụ huynh" : "Thêm phụ huynh mới";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-lg mx-auto overflow-hidden max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formParent" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="UserId" value="@Model.UserId" />

        <!-- Ho va ten -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Họ và tên <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="FullName"
                   id="fullName"
                   value="@Model.FullName"
                   placeholder="VD: Nguyen Van C"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
        </div>

        <!-- Gioi tinh & Quan he -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Giới tính</label>
                <select name="Gender"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="">-- Chọn --</option>
                    @if (Model.Gender == 1)
                    {
                        <option value="1" selected>Nam</option>
                    }
                    else
                    {
                        <option value="1">Nam</option>
                    }
                    @if (Model.Gender == 2)
                    {
                        <option value="2" selected>Nu</option>
                    }
                    else
                    {
                        <option value="2">Nu</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Quan hệ với HS</label>
                <select name="Relationship"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="">-- Chọn --</option>
                    @if (Model.Relationship == 1)
                    {
                        <option value="1" selected>Cha</option>
                    }
                    else
                    {
                        <option value="1">Cha</option>
                    }
                    @if (Model.Relationship == 2)
                    {
                        <option value="2" selected>Me</option>
                    }
                    else
                    {
                        <option value="2">Me</option>
                    }
                    @if (Model.Relationship == 3)
                    {
                        <option value="3" selected>Người giám hộ</option>
                    }
                    else
                    {
                        <option value="3">Người giám hộ</option>
                    }
                </select>
            </div>
        </div>

        <!-- So dien thoai & Email -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Số điện thoại <span class="text-red-500">*</span>
                </label>
                <input type="text"
                       name="Phone"
                       id="phone"
                       value="@Model.Phone"
                       placeholder="VD: 0912345678"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                       required />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email</label>
                <input type="email"
                       name="Email"
                       value="@Model.Email"
                       placeholder="VD: parent@email.com"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
        </div>

        <!-- Nghe nghiep -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Nghề nghiệp</label>
            <input type="text"
                   name="Occupation"
                   value="@Model.Occupation"
                   placeholder="VD: Kỹ sư, Giáo viên, Buôn bán"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Dia chi -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Địa chỉ</label>
            <input type="text"
                   name="Address"
                   value="@Model.Address"
                   placeholder="VD: 123 Duong ABC, Quan 1, TP.HCM"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bỏ
            </button>
            <button type="button"
                    onclick="submitParentForm()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Thêm phụ huynh")
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitParentForm() {
        var fullName = $('#fullName').val();
        var phone = $('#phone').val();

        if (!fullName || !fullName.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Họ tên không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        if (!phone || !phone.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Số điện thoại không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var form = document.getElementById('formParent');
        var formData = new FormData(form);

        $.ajax({
            url: '@Url.Action("Save", "Parent")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Loi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Loi',
                    text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
