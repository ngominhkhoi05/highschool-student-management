@model QuanLyHocSinh.Models.SchoolYear

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sua nam hoc" : "Them nam hoc moi";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="$('#modalContainer').fadeOut().addClass('hidden').removeClass('flex')"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formSchoolYear" method="post" action="@Url.Action("SaveSchoolYear", "SchoolYear")" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <!-- Ten nam hoc -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Ten nam hoc <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="Name"
                   value="@Model.Name"
                   placeholder="VD: 2025-2026"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
            <p class="text-xs text-slate-400 mt-1">VD: 2025-2026</p>
        </div>

        <!-- Tu ngay -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Tu ngay
            </label>
            <input type="date"
                   name="StartDate"
                   value="@(Model.StartDate?.ToString("yyyy-MM-dd") ?? "")"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
        </div>

        <!-- Den ngay -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Den ngay
            </label>
            <input type="date"
                   name="EndDate"
                   value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "")"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
        </div>

        <!-- Tao hoc ky tu dong (chi hien khi them moi) -->
        @if (!isEdit)
        {
            <div class="flex items-center gap-3 p-3 bg-green-50 rounded-xl border border-green-100">
                <input type="checkbox"
                       id="autoCreateSemesters"
                       name="autoCreateSemesters"
                       value="true"
                       class="w-4 h-4 text-green-600 rounded border-slate-300 focus:ring-green-500"
                       checked />
                <label for="autoCreateSemesters" class="text-sm text-slate-700 select-none cursor-pointer">
                    <span class="font-semibold">Tu dong tao 2 hoc ky mac dinh</span>
                    <span class="text-slate-500 block text-xs">Hoc ky 1 va Hoc ky 2 se duoc tao cung luc</span>
                </label>
            </div>
        }

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="$('#modalContainer').fadeOut().addClass('hidden').removeClass('flex')"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bo
            </button>
            <button type="submit"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Luu thay doi" : "Tao nam hoc")
            </button>
        </div>
    </form>
</div>

<script>
    $(document).ready(function() {
        $('#formSchoolYear').on('submit', function(e) {
            e.preventDefault();
            var form = $(this);
            var url = form.attr('action');
            var formData = form.serialize();

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                success: function(result) {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thanh cong!',
                            text: result.message,
                            confirmButtonColor: '#006b2c'
                        }).then(function() {
                            $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Loi',
                            text: result.message,
                            confirmButtonColor: '#006b2c'
                        });
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Loi',
                        text: 'Khong the luu du lieu. Vui long thu lai.',
                        confirmButtonColor: '#006b2c'
                    });
                }
            });
        });
    });
</script>
