@model QuanLyHocSinh.Models.Semester

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa học kỳ" : "Thêm học kỳ mới";
    var syStart = ViewBag.SchoolYearStart ?? "";
    var syEnd = ViewBag.SchoolYearEnd ?? "";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="$('#modalContainer').fadeOut().addClass('hidden').removeClass('flex')"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formSemester" method="post" action="@Url.Action("SaveSemester", "SchoolYear")" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="SchoolYearId" value="@Model.SchoolYearId" />
        <input type="hidden" id="syStart" value="@syStart" />
        <input type="hidden" id="syEnd" value="@syEnd" />

        <!-- Thông tin năm học -->
        <div class="flex items-center gap-2 px-3 py-2 bg-slate-50 rounded-lg text-sm text-slate-600">
            <span class="material-symbols-outlined text-base text-green-600">calendar_today</span>
            <span>Năm học: <strong class="text-slate-800">@ViewBag.SchoolYearName</strong></span>
            @if (!string.IsNullOrEmpty(syStart) || !string.IsNullOrEmpty(syEnd))
            {
                <span class="ml-1 text-slate-400">
                    (@(syStart != "" ? Convert.ToDateTime(syStart).ToString("dd/MM/yyyy") : "?") - @(syEnd != "" ? Convert.ToDateTime(syEnd).ToString("dd/MM/yyyy") : "?"))
                </span>
            }
        </div>

        <!-- Số thứ tự học kỳ -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Số thứ tự <span class="text-red-500">*</span>
            </label>
            <select name="SemesterNumber" id="semesterNumber"
                    class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                <option value="">-- Chọn học kỳ --</option>
                @if (Model.SemesterNumber == 1)
                {
                    <option value="1" selected>1 - Học kỳ 1</option>
                }
                else
                {
                    <option value="1">1 - Học kỳ 1</option>
                }
                @if (Model.SemesterNumber == 2)
                {
                    <option value="2" selected>2 - Học kỳ 2</option>
                }
                else
                {
                    <option value="2">2 - Học kỳ 2</option>
                }
            </select>
        </div>

        <!-- Tên học kỳ -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Tên học kỳ <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="Name"
                   id="semesterName"
                   value="@Model.Name"
                   placeholder="VD: Học kỳ 1"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
            <p class="text-xs text-slate-400 mt-1">VD: Học kỳ 1, Học kỳ 2</p>
        </div>

        <!-- Từ ngày -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Từ ngày
            </label>
            <input type="date"
                   name="StartDate"
                   id="startDate"
                   value="@(Model.StartDate?.ToString("yyyy-MM-dd") ?? "")"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
        </div>

        <!-- Đến ngày -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Đến ngày
            </label>
            <input type="date"
                   name="EndDate"
                   id="endDate"
                   value="@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "")"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="$('#modalContainer').fadeOut().addClass('hidden').removeClass('flex')"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Hủy bỏ
            </button>
            <button type="submit"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Tạo học kỳ")
            </button>
        </div>
    </form>
</div>

<script>
    $(document).ready(function() {
        var syStart = $('#syStart').val();
        var syEnd = $('#syEnd').val();

        function autoFillDates(semNum) {
            if (!syStart || !syEnd) return;

            var start = new Date(syStart);
            var end = new Date(syEnd);
            var msInYear = end - start;
            var halfYear = new Date(start.getTime() + msInYear / 2);

            if (semNum == 1) {
                // HK1: từ đầu năm học đến giữa năm học
                var endHk1 = new Date(halfYear);
                endHk1.setDate(endHk1.getDate() - 1);

                $('#semesterName').val('Học kỳ 1');
                $('#startDate').val(syStart);
                $('#endDate').val(endHk1.toISOString().split('T')[0]);
            } else if (semNum == 2) {
                // HK2: từ giữa năm học đến cuối năm học
                var startHk2 = new Date(halfYear);

                $('#semesterName').val('Học kỳ 2');
                $('#startDate').val(startHk2.toISOString().split('T')[0]);
                $('#endDate').val(syEnd);
            }
        }

        $('select[name="SemesterNumber"]').on('change', function() {
            var num = parseInt($(this).val());
            autoFillDates(num);
        });

        $('#formSemester').on('submit', function(e) {
            e.preventDefault();

            if (!$('select[name="SemesterNumber"]').val()) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Vui lòng chọn số thứ tự học kỳ.',
                    confirmButtonColor: '#006b2c'
                });
                return;
            }

            var form = $(this);
            var formData = form.serialize();

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: formData,
                success: function(result) {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: result.message,
                            confirmButtonColor: '#006b2c'
                        }).then(function() {
                            $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi',
                            text: result.message,
                            confirmButtonColor: '#006b2c'
                        });
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                        confirmButtonColor: '#006b2c'
                    });
                }
            });
        });
    });
</script>
