@model highschool_student_management.ViewModels.ClassFormViewModel

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa lớp học" : "Thêm lớp học mới";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formClass" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <!-- Tên lớp -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Tên lớp <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="Name"
                   id="name"
                   value="@Model.Name"
                   placeholder="VD: 10A1, 11B2"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300 uppercase"
                   required />
        </div>

        <!-- Khối lớp & Năm học -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Khối lớp</label>
                <select name="GradeLevel"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="">-- Chọn --</option>
                    @if (Model.GradeLevel == 10)
                    {
                        <option value="10" selected>10</option>
                    }
                    else
                    {
                        <option value="10">10</option>
                    }
                    @if (Model.GradeLevel == 11)
                    {
                        <option value="11" selected>11</option>
                    }
                    else
                    {
                        <option value="11">11</option>
                    }
                    @if (Model.GradeLevel == 12)
                    {
                        <option value="12" selected>12</option>
                    }
                    else
                    {
                        <option value="12">12</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                    Năm học <span class="text-red-500">*</span>
                </label>
                <select name="SchoolYearId"
                        id="schoolYearId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="">-- Chọn năm học --</option>
                    @foreach (var sy in Model.SchoolYears)
                    {
                        if (Model.SchoolYearId == sy.Id)
                        {
                            <option value="@sy.Id" selected>@sy.Name</option>
                        }
                        else
                        {
                            <option value="@sy.Id">@sy.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Giao vien chu nhiem & Si so -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Giáo viên chủ nhiệm</label>
                <select name="HomeroomTeacherId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="0">-- Chọn GVCN --</option>
                    @foreach (var t in Model.Teachers)
                    {
                        if (Model.HomeroomTeacherId == t.Id)
                        {
                            <option value="@t.Id" selected>@t.FullName</option>
                        }
                        else
                        {
                            <option value="@t.Id">@t.FullName</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Sỉ số tối đa</label>
                <input type="number"
                       name="MaxStudents"
                       value="@Model.MaxStudents"
                       placeholder="VD: 40"
                       min="1"
                       max="100"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
        </div>

        <!-- Phòng học -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Phòng học</label>
            <input type="text"
                   name="Room"
                   value="@Model.Room"
                   placeholder="VD: P301, A102"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bỏ
            </button>
            <button type="button"
                    onclick="submitClassForm()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Thêm lớp học")
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitClassForm() {
        var name = $('#name').val();
        var schoolYearId = $('#schoolYearId').val();

        if (!name || !name.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Tên lớp không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        if (!schoolYearId) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Vui lòng chọn năm học.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var form = document.getElementById('formClass');
        var formData = new FormData(form);

        $.ajax({
            url: '@Url.Action("SaveClass", "Class")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                                    title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
