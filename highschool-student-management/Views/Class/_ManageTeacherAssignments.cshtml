@model highschool_student_management.ViewModels.ManageTeacherAssignmentsViewModel

<div class="bg-white rounded-2xl shadow-xl w-full max-w-3xl mx-auto overflow-hidden max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <div>
            <h3 class="text-white font-bold text-lg">Phân công giáo viên</h3>
            <p class="text-green-100 text-xs mt-0.5">@Model.ClassName</p>
        </div>
        <button type="button" onclick="closeManageModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <div class="p-6 space-y-6">
        <!-- Form them phan cong moi -->
        <div class="bg-green-50 rounded-xl p-4 space-y-3">
            <h4 class="font-bold text-slate-700 text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-green-600 text-base">add_circle</span>
                Thêm phân công mới
            </h4>
            <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Môn học</label>
                    <select id="newSubjectId"
                            class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                        <option value="">-- Chọn môn --</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.Id">@s.Name (@s.Code)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Giáo viên</label>
                    <select id="newTeacherId"
                            class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                        <option value="">-- Chọn giáo viên --</option>
                        @foreach (var t in Model.Teachers)
                        {
                            <option value="@t.Id">@t.FullName @(string.IsNullOrEmpty(t.Specialization) ? "" : $"({t.Specialization})")</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Học kỳ</label>
                    <select id="newSemesterId"
                            class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                        <option value="">-- Chọn học kỳ --</option>
                        @foreach (var sem in Model.Semesters)
                        {
                            <option value="@sem.Id">@sem.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Số tiết/tuần</label>
                    <input type="number"
                           id="newPeriodsPerWeek"
                           min="1" max="20"
                           placeholder="VD: 4"
                           class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                </div>
            </div>
            <button type="button"
                    onclick="saveAssignment()"
                    class="w-full px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-base">add</span>
                Phân công
            </button>
        </div>

        <!-- Danh sach phan cong hien tai -->
        <div class="space-y-3">
            <h4 class="font-bold text-slate-700 text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-green-600 text-base">list</span>
                Các phân công hiện tại
                <span class="text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full ml-1">@Model.CurrentAssignments.Count</span>
            </h4>
            <div id="assignmentsList" class="space-y-2 max-h-[350px] overflow-y-auto">
                @if (!Model.CurrentAssignments.Any())
                {
                    <div class="text-center py-8 text-slate-400">
                        <span class="material-symbols-outlined text-3xl">assignment_turned_in</span>
                            <p class="text-xs mt-1">Chưa có phân công nào</p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-50 text-slate-600">
                                <tr>
                                    <th class="px-4 py-2.5 text-left font-semibold text-xs">Môn học</th>
                                    <th class="px-4 py-2.5 text-left font-semibold text-xs">Giáo viên</th>
                                    <th class="px-4 py-2.5 text-left font-semibold text-xs">Học kỳ</th>
                                    <th class="px-4 py-2.5 text-center font-semibold text-xs w-20">Số tiết</th>
                                    <th class="px-4 py-2.5 text-center font-semibold text-xs w-16">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.CurrentAssignments)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-green-50/30 transition-colors" id="assignment-row-@a.Id">
                                        <td class="px-4 py-2.5 font-medium text-slate-700">@a.SubjectName</td>
                                        <td class="px-4 py-2.5 text-slate-600">@a.TeacherName</td>
                                        <td class="px-4 py-2.5 text-slate-600 text-xs">@a.SemesterName</td>
                                        <td class="px-4 py-2.5 text-center text-slate-600">@(a.PeriodsPerWeek?.ToString() ?? "-")</td>
                                        <td class="px-4 py-2.5 text-center">
                                            <button type="button"
                                                    onclick="removeAssignment(@a.Id, '@a.SubjectName')"
                                                    class="p-1 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded transition-all"
                                                    title="Xóa phân công">
                                                <span class="material-symbols-outlined text-base">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function closeManageModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function reloadAssignments() {
        $.ajax({
            url: '@Url.Action("_ManageTeacherAssignments", "Class")',
            type: 'GET',
            data: { classId: @Model.ClassId },
            success: function(html) {
                $('#modalBody').html(html);
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể tải lại dữ liệu.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }

    function saveAssignment() {
        var subjectId = parseInt($('#newSubjectId').val());
        var teacherId = parseInt($('#newTeacherId').val());
        var semesterId = parseInt($('#newSemesterId').val());
        var periods = parseInt($('#newPeriodsPerWeek').val()) || null;

        if (!subjectId || !teacherId || !semesterId) {
            Swal.fire({
                icon: 'warning',
                title: 'Chưa điền đầy thông tin',
                text: 'Vui lòng chọn đầy đủ Môn học, Giáo viên và Học kỳ.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        $.ajax({
            url: '@Url.Action("SaveTeacherAssignment", "Class")',
            type: 'POST',
            data: {
                classId: @Model.ClassId,
                subjectId: subjectId,
                teacherId: teacherId,
                semesterId: semesterId,
                periodsPerWeek: periods,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                    reloadAssignments();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể lưu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }

    function removeAssignment(id, subjectName) {
        Swal.fire({
            title: 'Xác nhận xóa',
            text: 'Bạn có muốn xóa phân công môn "' + subjectName + '"?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'Xóa',
            cancelButtonText: 'Hủy bỏ'
        }).then(function(result) {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("RemoveTeacherAssignment", "Class")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function(result) {
                        if (result.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: result.message,
                                confirmButtonColor: '#006b2c'
                            });
                            reloadAssignments();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: result.message,
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi',
                            text: 'Không thể xóa. Vui lòng thử lại.',
                            confirmButtonColor: '#006b2c'
                        });
                    }
                });
            }
        });
    }
</script>
