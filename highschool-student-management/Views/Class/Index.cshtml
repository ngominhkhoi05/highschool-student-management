@model List<highschool_student_management.ViewModels.ClassIndexViewModel>

@{
    ViewData["Title"] = "Lop hoc";
}

<div class="max-w-6xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Lop hoc</h1>
            <p class="text-sm text-slate-500 mt-1">Quan ly danh sach lop hoc</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm"
                data-url="@Url.Action("_CreateOrEdit", "Class", new { id = 0 })"
                data-title="Them lop hoc moi">
            <span class="material-symbols-outlined text-lg">add</span>
            Them lop hoc
        </button>
    </div>

    <!-- Bang danh sach -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <form method="get" class="flex-1 flex items-center gap-3">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input type="text"
                           name="search"
                           value="@ViewData["Search"]"
                           placeholder="Tim kiem theo ten lop hoac phong hoc..."
                           class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                </div>
                <button type="submit"
                        class="px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm">
                    Tim kiem
                </button>
                @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                {
                    <a asp-action="Index"
                       class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">
                        Xoa loc
                    </a>
                }
            </form>
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-4 py-4 text-left font-semibold w-12">#</th>
                    <th class="px-4 py-4 text-left font-semibold">Ten lop</th>
                    <th class="px-4 py-4 text-center font-semibold">Khoi</th>
                    <th class="px-4 py-4 text-left font-semibold">Nam hoc</th>
                    <th class="px-4 py-4 text-center font-semibold">Si so</th>
                    <th class="px-4 py-4 text-left font-semibold">Phong hoc</th>
                    <th class="px-4 py-4 text-left font-semibold">Giao vien chu nhiem</th>
                    <th class="px-4 py-4 text-center font-semibold w-48">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">school</span>
                            <p class="mt-2">Chua co lop hoc nao.</p>
                        </td>
                    </tr>
                }
                else
                {
                    var idx = 1;
                    foreach (var cls in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors">
                            <td class="px-4 py-3 text-slate-400 text-xs font-medium">@idx</td>
                            <td class="px-4 py-3">
                                <span class="font-bold text-green-700">@cls.Name</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex items-center px-2.5 py-0.5 bg-slate-100 text-slate-600 text-xs font-semibold rounded-full">
                                    @cls.GradeLevel
                                </span>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@cls.SchoolYearName</td>
                            <td class="px-4 py-3 text-center">
                                <span class="font-semibold @(cls.MaxStudents.HasValue && cls.CurrentStudentCount >= cls.MaxStudents ? "text-red-600" : "text-slate-700")">
                                    @(cls.CurrentStudentCount) / @(cls.MaxStudents.HasValue ? cls.MaxStudents.ToString() : "-")
                                </span>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(cls.Room) ? "-" : cls.Room)</td>
                            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(cls.HomeroomTeacherName) ? "-" : cls.HomeroomTeacherName)</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-1">
                                    <!-- Nut Xep lop -->
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                                            title="Xep lop hoc sinh"
                                            data-url="@Url.Action("_ManageStudents", "Class", new { classId = cls.Id })"
                                            data-title="Xep lop - @cls.Name">
                                        <span class="material-symbols-outlined text-base">group</span>
                                    </button>
                                    <!-- Nut Phan cong -->
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-purple-600 hover:bg-purple-50 rounded-lg transition-all btn-render-modal"
                                            title="Phan cong giao vien"
                                            data-url="@Url.Action("_ManageTeacherAssignments", "Class", new { classId = cls.Id })"
                                            data-title="Phan cong - @cls.Name">
                                        <span class="material-symbols-outlined text-base">assignment</span>
                                    </button>
                                    <!-- Nut Sua -->
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                                            title="Sua"
                                            data-url="@Url.Action("_CreateOrEdit", "Class", new { id = cls.Id })"
                                            data-title="Sua lop hoc">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <!-- Nut Xoa -->
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xoa"
                                            onclick="deleteClass(@cls.Id, '@cls.Name')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        idx++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteClass(id, name) {
            Swal.fire({
                title: 'Xac nhan xoa',
                text: 'Ban co muon xoa lop "' + name + '" khong?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xoa',
                cancelButtonText: 'Huy bo'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteClass", "Class")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thanh cong!',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                }).then(function() {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Loi',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Loi',
                                text: 'Khong the xoa. Vui long thu lai.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
