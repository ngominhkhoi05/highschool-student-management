@model List<highschool_student_management.ViewModels.ClassIndexViewModel>

@{
    ViewData["Title"] = "Lớp học";
}

<div class="max-w-6xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Lớp học</h1>
            <p class="text-sm text-slate-500 mt-1">Quản lý danh sách lớp học</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm"
                data-url="@Url.Action("_CreateOrEdit", "Class", new { id = 0 })"
                data-title="Thêm lớp học mới">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm lớp học
        </button>
    </div>

    <!-- Bang danh sach -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <div class="relative flex-1 max-w-md">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                <input type="text"
                       id="searchInput"
                       value="@ViewData["Search"]"
                       placeholder="Tìm kiếm theo tên lớp hoặc phòng học..."
                       class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
            <span id="searchCount" class="text-sm text-slate-400 whitespace-nowrap"></span>
            @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
            {
                <a id="btnClearFilter" asp-action="Index" class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">Xóa lọc</a>
            }
            else
            {
                <span id="btnClearFilter" class="hidden px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all cursor-pointer">Xóa lọc</span>
            }
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-4 py-4 text-left font-semibold w-12">#</th>
                    <th class="px-4 py-4 text-left font-semibold">Tên lớp</th>
                    <th class="px-4 py-4 text-center font-semibold">Khối</th>
                    <th class="px-4 py-4 text-left font-semibold">Năm học</th>
                    <th class="px-4 py-4 text-center font-semibold">Sĩ số</th>
                    <th class="px-4 py-4 text-left font-semibold">Phòng học</th>
                    <th class="px-4 py-4 text-left font-semibold">Giáo viên chủ nhiệm</th>
                    <th class="px-4 py-4 text-center font-semibold w-48">Thao tác</th>
                </tr>
            </thead>
            <tbody id="classTableBody">
                @await Html.PartialAsync("_TableBody", Model)
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        var searchTimer = null;

        function reloadTable(searchValue) {
            $.ajax({
                url: '@Url.Action("Index", "Class")',
                type: 'GET',
                data: { search: searchValue },
                success: function(html) {
                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');
                    var newBody = doc.querySelector('#classTableBody');
                    if (newBody) {
                        $('#classTableBody').html(newBody.innerHTML);
                    }
                },
                error: function() {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể tải dữ liệu.', confirmButtonColor: '#006b2c' });
                }
            });
        }

        function updateSearchUI(count, searchValue) {
            var countEl = $('#searchCount');
            if (searchValue && searchValue.length > 0) {
                countEl.text(count + ' kết quả');
                $('#btnClearFilter').removeClass('hidden').addClass('inline-flex items-center gap-2');
                $('#btnClearFilter').html('<span class="material-symbols-outlined text-base">close</span> Xóa lọc');
                $('#btnClearFilter').unbind('click').on('click', function() {
                    $('#searchInput').val('');
                    reloadTable('');
                });
            } else {
                countEl.text('');
                $('#btnClearFilter').addClass('hidden').removeClass('inline-flex items-center gap-2');
            }
        }

        $(document).ready(function() {
            var initialCount = @Model.Count();
            updateSearchUI(initialCount, '@ViewData["Search"]');

            $('#searchInput').on('input', function() {
                var value = $(this).val();
                clearTimeout(searchTimer);
                searchTimer = setTimeout(function() {
                    reloadTable(value);
                    updateSearchUI($('#classTableBody tr').length, value);
                }, 350);
            });
        });

        function deleteClass(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa',
                text: 'Bạn có muốn xóa lớp "' + name + '" không?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteClass", "Class")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({ icon: 'success', title: 'Thành công!', text: result.message, confirmButtonColor: '#006b2c' }).then(function() {
                                    var currentSearch = $('#searchInput').val();
                                    reloadTable(currentSearch);
                                    updateSearchUI($('#classTableBody tr').length, currentSearch);
                                });
                            } else {
                                Swal.fire({ icon: 'error', title: 'Lỗi', text: result.message, confirmButtonColor: '#006b2c' });
                            }
                        },
                        error: function() {
                            Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể xóa.', confirmButtonColor: '#006b2c' });
                        }
                    });
                }
            });
        }
    </script>
}
