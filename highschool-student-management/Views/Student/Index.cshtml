@model List<highschool_student_management.ViewModels.StudentIndexViewModel>

@{
    ViewData["Title"] = "Học sinh";
}

<div class="max-w-6xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Học sinh</h1>
            <p class="text-sm text-slate-500 mt-1">Quan ly danh sach hoc sinh</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm"
                data-url="@Url.Action("_CreateOrEdit", "Student", new { id = 0 })"
                data-title="Thêm học sinh mới">
            <span class="material-symbols-outlined text-lg">add</span>
            Thêm học sinh
        </button>
    </div>

    <!-- Bang danh sach -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <form method="get" class="flex-1 flex items-center gap-3">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input type="text"
                           name="search"
                           value="@ViewData["Search"]"
                           placeholder="Tìm kiếm theo tên, mã học sinh hoặc số điện thoại..."
                           class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                </div>
                <button type="submit"
                        class="px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm">
                    Tìm kiếm
                </button>
                @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                {
                    <a asp-action="Index"
                       class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">
                        Xóa lọc
                    </a>
                }
            </form>
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-4 py-4 text-left font-semibold w-16">Anh</th>
                    <th class="px-4 py-4 text-left font-semibold">Mã HS</th>
                    <th class="px-4 py-4 text-left font-semibold">Họ và tên</th>
                    <th class="px-4 py-4 text-left font-semibold">Giới tính</th>
                    <th class="px-4 py-4 text-left font-semibold">Ngay sinh</th>
                    <th class="px-4 py-4 text-center font-semibold">Trang thai</th>
                    <th class="px-4 py-4 text-center font-semibold w-24">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">school</span>
                            <p class="mt-2">Chưa có học sinh nào.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var student in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors">
                            <td class="px-4 py-3">
                                @if (!string.IsNullOrEmpty(student.Avatar))
                                {
                                    <img src="@student.Avatar" alt="Avatar" class="w-10 h-10 rounded-full object-cover" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-full bg-blue-200 text-blue-700 flex items-center justify-center text-sm font-bold">
                                        @student.FullName[0].ToString().ToUpper()
                                    </div>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <span class="font-semibold text-green-700">@student.StudentCode</span>
                            </td>
                            <td class="px-4 py-3">
                                <p class="font-semibold text-slate-800">@student.FullName</p>
                                <p class="text-xs text-slate-400">@student.Phone</p>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@student.GenderName</td>
                            <td class="px-4 py-3 text-slate-600">@(student.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-full @(student.Status == 1 ? "bg-green-100 text-green-700" : student.Status == 2 ? "bg-yellow-100 text-yellow-700" : student.Status == 3 ? "bg-blue-100 text-blue-700" : "bg-slate-100 text-slate-700")">
                                    @student.StatusName
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                                            title="Sửa"
                                            data-url="@Url.Action("_CreateOrEdit", "Student", new { id = student.Id })"
                                            data-title="Sửa học sinh">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xóa"
                                            onclick="deleteStudent(@student.Id, '@student.FullName')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteStudent(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa',
                text: 'Bạn có muốn xóa học sinh "' + name + '" không? Hành động này sẽ xóa cả tài khoản liên quan.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Student")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công!',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                }).then(function() {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Loi',
                                text: 'Không thể xóa. Vui lòng thử lại.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
