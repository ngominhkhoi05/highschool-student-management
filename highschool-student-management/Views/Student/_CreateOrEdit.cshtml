@model highschool_student_management.ViewModels.StudentFormViewModel

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa học sinh" : "Thêm học sinh mới";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-lg mx-auto overflow-hidden max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formStudent" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="UserId" value="@Model.UserId" />
        <input type="hidden" name="Avatar" value="@Model.Avatar" />

        <!-- Avatar -->
        <div class="flex flex-col items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.Avatar))
            {
                <img id="avatarPreview" src="@Model.Avatar" alt="Avatar" class="w-24 h-24 rounded-full object-cover border-2 border-green-200" />
            }
            else
            {
                <div id="avatarPreview" class="w-24 h-24 rounded-full bg-blue-200 text-blue-700 flex items-center justify-center text-3xl font-bold border-2 border-green-200">
                    @(string.IsNullOrEmpty(Model.FullName) ? "?" : Model.FullName[0].ToString().ToUpper())
                </div>
            }
            <label class="cursor-pointer px-4 py-2 text-sm font-semibold text-green-600 hover:text-green-700 hover:bg-green-50 rounded-lg transition-all">
                <span class="material-symbols-outlined text-base align-middle mr-1">upload</span>
                Chọn ảnh đại diện
                <input type="file" name="AvatarFile" id="avatarInput" accept="image/*" class="hidden" onchange="previewAvatar(this)" />
            </label>
        </div>

        <!-- Mã học sinh -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Mã học sinh
            </label>
            @if (isEdit)
            {
                <input type="text"
                       value="@Model.StudentCode"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-100 text-slate-500 cursor-not-allowed"
                       readonly />
                <input type="hidden" name="StudentCode" value="@Model.StudentCode" />
            }
            else
            {
                <input type="text"
                       name="StudentCode"
                       id="studentCode"
                       value="@Model.StudentCode"
                       placeholder="VD: HS2025001"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300 uppercase"
                       required />
            }
        </div>

        <!-- Họ và tên -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Họ và tên <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   name="FullName"
                   id="fullName"
                   value="@Model.FullName"
                   placeholder="VD: Nguyen Van B"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300"
                   required />
        </div>

        <!-- Giới tính & Ngày sinh -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Giới tính</label>
                <select name="Gender"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    <option value="">-- Chọn --</option>
                    @if (Model.Gender == 1)
                    {
                        <option value="1" selected>Nam</option>
                    }
                    else
                    {
                        <option value="1">Nam</option>
                    }
                    @if (Model.Gender == 2)
                    {
                        <option value="2" selected>Nu</option>
                    }
                    else
                    {
                        <option value="2">Nu</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Ngày sinh</label>
                <input type="date"
                       name="DateOfBirth"
                       value="@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("yyyy-MM-dd") : "")"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
            </div>
        </div>

        <!-- Nơi sinh & Dân tộc -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Nơi sinh</label>
                <input type="text"
                       name="PlaceOfBirth"
                       value="@Model.PlaceOfBirth"
                       placeholder="VD: TP.HCM"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Dân tộc</label>
                <input type="text"
                       name="Ethnicity"
                       value="@Model.Ethnicity"
                       placeholder="VD: Kinh"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
        </div>

        <!-- Tôn giáo & Số điện thoại -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Tôn giáo</label>
                <input type="text"
                       name="Religion"
                       value="@Model.Religion"
                       placeholder="VD: Phat giao"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Số điện thoại</label>
                <input type="text"
                       name="Phone"
                       value="@Model.Phone"
                       placeholder="VD: 0912345678"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
            </div>
        </div>

        <!-- Địa chỉ -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Địa chỉ</label>
            <input type="text"
                   name="Address"
                   value="@Model.Address"
                   placeholder="VD: 123 Duong ABC, Quan 1, TP.HCM"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Ngày nhập học & Trạng thái -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Ngày nhập học</label>
                <input type="date"
                       name="EnrollmentDate"
                       value="@(Model.EnrollmentDate.HasValue ? Model.EnrollmentDate.Value.ToString("yyyy-MM-dd") : DateTime.Now.ToString("yyyy-MM-dd"))"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Trạng thái</label>
                <select name="Status"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all bg-white">
                    @if (Model.Status == 1)
                    {
                        <option value="1" selected>Dang hoc</option>
                    }
                    else
                    {
                        <option value="1">Dang hoc</option>
                    }
                    @if (Model.Status == 2)
                    {
                        <option value="2" selected>Nghi hoc</option>
                    }
                    else
                    {
                        <option value="2">Nghi hoc</option>
                    }
                    @if (Model.Status == 3)
                    {
                        <option value="3" selected>Tot nghiep</option>
                    }
                    else
                    {
                        <option value="3">Tot nghiep</option>
                    }
                    @if (Model.Status == 4)
                    {
                        <option value="4" selected>Chuyen truong</option>
                    }
                    else
                    {
                        <option value="4">Chuyen truong</option>
                    }
                </select>
            </div>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Huy bỏ
            </button>
            <button type="button"
                    onclick="submitStudentForm()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Thêm học sinh")
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var preview = document.getElementById('avatarPreview');
                preview.outerHTML = '<img id="avatarPreview" src="' + e.target.result + '" alt="Avatar" class="w-24 h-24 rounded-full object-cover border-2 border-green-200" />';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function submitStudentForm() {
        var fullName = $('#fullName').val();
        var studentCode = $('#studentCode').val();

        if (!fullName || !fullName.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Họ tên không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        if (!studentCode || !studentCode.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Mã học sinh không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var form = document.getElementById('formStudent');
        var formData = new FormData(form);

        $.ajax({
            url: '@Url.Action("Save", "Student")',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
