@model highschool_student_management.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="p-6 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Bảng điều khiển</h1>
            <p class="text-sm text-slate-500">Năm học: @Model.SchoolYearName @(Model.SemesterName != "" ? " - " + Model.SemesterName : "")</p>
        </div>
    </div>

    <!-- Cards tong quan -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-green-50 border border-green-200 rounded-2xl p-6 flex items-center gap-4">
            <div class="w-14 h-14 bg-green-500 rounded-2xl flex items-center justify-center text-white shadow-sm">
                <span class="material-symbols-outlined text-2xl">groups</span>
            </div>
            <div>
                <p class="text-3xl font-bold text-green-800">@Model.TotalStudents</p>
                <p class="text-sm text-green-600 font-medium">Học sinh đang học</p>
            </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 flex items-center gap-4">
            <div class="w-14 h-14 bg-blue-500 rounded-2xl flex items-center justify-center text-white shadow-sm">
                <span class="material-symbols-outlined text-2xl">school</span>
            </div>
            <div>
                <p class="text-3xl font-bold text-blue-800">@Model.TotalTeachers</p>
                <p class="text-sm text-blue-600 font-medium">Giáo viên đang dạy</p>
            </div>
        </div>

        <div class="bg-purple-50 border border-purple-200 rounded-2xl p-6 flex items-center gap-4">
            <div class="w-14 h-14 bg-purple-500 rounded-2xl flex items-center justify-center text-white shadow-sm">
                <span class="material-symbols-outlined text-2xl">class</span>
            </div>
            <div>
                <p class="text-3xl font-bold text-purple-800">@Model.TotalClasses</p>
                <p class="text-sm text-purple-600 font-medium">Lớp học hiện tại</p>
            </div>
        </div>
    </div>

    <!-- Bieu do xep loai hoc luc -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-6">
        <h2 class="text-lg font-bold text-slate-800 mb-1">Thống kê xếp loại học lực</h2>
        <p class="text-sm text-slate-500 mb-6">@Model.SemesterName</p>

        @if (!Model.AcademicRankStats.Any())
        {
            <div class="text-center py-12 text-slate-400">
                <span class="material-symbols-outlined text-5xl">analytics</span>
                <p class="mt-3 font-medium">Chưa có dữ liệu xếp loại học lực</p>
                <p class="text-sm mt-1">Vui lòng đảm bảo đã có kết quả học kỳ được tạo.</p>
            </div>
        }
        else
        {
            var total = Model.AcademicRankStats.Sum(s => s.Count);
            var chartData = Model.AcademicRankStats
                .Where(s => s.Rank > 0)
                .Select(s => new { label = s.RankName, count = s.Count })
                .ToList();

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
                <div class="relative">
                    <canvas id="myChart" height="280"></canvas>
                </div>
                <div class="space-y-3">
                    @foreach (var stat in Model.AcademicRankStats.Where(s => s.Rank > 0).OrderBy(s => s.Rank))
                    {
                        var pct = total > 0 ? (stat.Count * 100.0 / total) : 0;
                        var colorClass = stat.Rank switch
                        {
                            1 => "bg-green-500",
                            2 => "bg-blue-500",
                            3 => "bg-yellow-500",
                            4 => "bg-orange-500",
                            5 => "bg-red-500",
                            _ => "bg-slate-400"
                        };
                        <div class="flex items-center gap-3">
                            <div class="w-28 text-sm font-medium text-slate-600 text-right">@stat.RankName</div>
                            <div class="flex-1 bg-slate-100 rounded-full h-3 overflow-hidden">
                                <div class="@colorClass h-full rounded-full transition-all duration-700"
                                     style="width: @pct.ToString("F1")%"></div>
                            </div>
                            <div class="w-20 text-sm font-semibold text-slate-700">@stat.Count <span class="font-normal text-slate-400">(@pct.ToString("F1")%)</span></div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var stats = @Html.Raw(Json.Serialize(Model.AcademicRankStats.Where(s => s.Rank > 0).ToList()));
            if (!stats || stats.length === 0) return;

            var labels = stats.map(function(s) { return s.rankName; });
            var data = stats.map(function(s) { return s.count; });
            var colors = [
                'rgba(34, 197, 94, 0.85)',   // Xanh la - Gioi
                'rgba(59, 130, 246, 0.85)', // Xanh duong - Kha
                'rgba(234, 179, 8, 0.85)',  // Vang - TB
                'rgba(249, 115, 22, 0.85)', // Cam - Yeu
                'rgba(239, 68, 68, 0.85)'   // Do - Kem
            ];

            var ctx = document.getElementById('myChart').getContext('2d');
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: colors.slice(0, data.length),
                        borderColor: '#ffffff',
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: { family: 'Lexend', size: 13 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    var total = data.reduce(function(a, b) { return a + b; }, 0);
                                    var pct = total > 0 ? ((context.parsed / total) * 100).toFixed(1) : 0;
                                    return context.label + ': ' + context.parsed + ' hoc sinh (' + pct + '%)';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
