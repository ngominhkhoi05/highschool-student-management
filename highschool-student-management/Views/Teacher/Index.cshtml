@model List<highschool_student_management.ViewModels.TeacherIndexViewModel>

@{
    ViewData["Title"] = "Giao vien";
}

<div class="max-w-6xl mx-auto">
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-green-700">Giao vien</h1>
            <p class="text-sm text-slate-500 mt-1">Quan ly danh sach giao vien</p>
        </div>
        <button class="btn-render-modal flex items-center gap-2 px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm"
                data-url="@Url.Action("_CreateOrEdit", "Teacher", new { id = 0 })"
                data-title="Them giao vien moi">
            <span class="material-symbols-outlined text-lg">add</span>
            Them giao vien
        </button>
    </div>

    <!-- Bang danh sach -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-4 border-b border-green-100 flex items-center gap-3">
            <form method="get" class="flex-1 flex items-center gap-3">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input type="text"
                           name="search"
                           value="@ViewData["Search"]"
                           placeholder="Tim kiem theo ten, email hoac so dien thoai..."
                           class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                </div>
                <button type="submit"
                        class="px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-all shadow-sm">
                    Tim kiem
                </button>
                @if (!string.IsNullOrEmpty(ViewData["Search"] as string))
                {
                    <a asp-action="Index"
                       class="px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-all">
                        Xoa loc
                    </a>
                }
            </form>
        </div>

        <!-- Bang du lieu -->
        <table class="w-full text-sm">
            <thead class="bg-green-600 text-white">
                <tr>
                    <th class="px-4 py-4 text-left font-semibold w-16">Anh</th>
                    <th class="px-4 py-4 text-left font-semibold">Ho va ten</th>
                    <th class="px-4 py-4 text-left font-semibold">Gioi tinh</th>
                    <th class="px-4 py-4 text-left font-semibold">Ngay sinh</th>
                    <th class="px-4 py-4 text-left font-semibold">So dien thoai</th>
                    <th class="px-4 py-4 text-left font-semibold">Chuyen mon</th>
                    <th class="px-4 py-4 text-center font-semibold">Trang thai</th>
                    <th class="px-4 py-4 text-center font-semibold w-36">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-slate-400">
                            <span class="material-symbols-outlined text-4xl">person_off</span>
                            <p class="mt-2">Chua co giao vien nao.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var teacher in Model)
                    {
                        <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors">
                            <td class="px-4 py-3">
                                @if (!string.IsNullOrEmpty(teacher.Avatar))
                                {
                                    <img src="@teacher.Avatar" alt="Avatar" class="w-10 h-10 rounded-full object-cover" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-full bg-green-200 text-green-700 flex items-center justify-center text-sm font-bold">
                                        @teacher.FullName[0].ToString().ToUpper()
                                    </div>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <p class="font-semibold text-slate-800">@teacher.FullName</p>
                                <p class="text-xs text-slate-400">@teacher.Email</p>
                            </td>
                            <td class="px-4 py-3 text-slate-600">@teacher.GenderName</td>
                            <td class="px-4 py-3 text-slate-600">@(teacher.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(teacher.Phone) ? "-" : teacher.Phone)</td>
                            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(teacher.Specialization) ? "-" : teacher.Specialization)</td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-full @(teacher.Status == 1 ? "bg-green-100 text-green-700" : teacher.Status == 2 ? "bg-yellow-100 text-yellow-700" : "bg-red-100 text-red-700")">
                                    @teacher.StatusName
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-1">
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                                            title="Sua"
                                            data-url="@Url.Action("_CreateOrEdit", "Teacher", new { id = teacher.Id })"
                                            data-title="Sua giao vien">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </button>
                                    <button type="button"
                                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                                            title="Xoa"
                                            onclick="deleteTeacher(@teacher.Id, '@teacher.FullName')">
                                        <span class="material-symbols-outlined text-base">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function deleteTeacher(id, name) {
            Swal.fire({
                title: 'Xac nhan xoa',
                text: 'Ban co muon xoa giao vien "' + name + '" khong? Hanh dong nay se xoa ca tai khoan lien quan.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Xoa',
                cancelButtonText: 'Huy bo'
            }).then(function(result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Delete", "Teacher")',
                        type: 'POST',
                        data: { id: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                        success: function(result) {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thanh cong!',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                }).then(function() {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Loi',
                                    text: result.message,
                                    confirmButtonColor: '#006b2c'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Loi',
                                text: 'Khong the xoa. Vui long thu lai.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
