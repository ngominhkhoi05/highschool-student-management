@model List<highschool_student_management.ViewModels.TeacherIndexViewModel>

@if (!Model.Any())
{
    <tr>
        <td colspan="8" class="px-6 py-12 text-center text-slate-400">
            <span class="material-symbols-outlined text-4xl">person_off</span>
            <p class="mt-2">Không có giáo viên nào phù hợp.</p>
        </td>
    </tr>
}
else
{
    foreach (var teacher in Model)
    {
        <tr class="odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors">
            <td class="px-4 py-3">
                @if (!string.IsNullOrEmpty(teacher.Avatar))
                {
                    <img src="@teacher.Avatar" alt="Avatar" class="w-10 h-10 rounded-full object-cover" />
                }
                else
                {
                    <div class="w-10 h-10 rounded-full bg-green-200 text-green-700 flex items-center justify-center text-sm font-bold">
                        @teacher.FullName[0].ToString().ToUpper()
                    </div>
                }
            </td>
            <td class="px-4 py-3">
                <p class="font-semibold text-slate-800">@teacher.FullName</p>
                <p class="text-xs text-slate-400">@teacher.Email</p>
            </td>
            <td class="px-4 py-3 text-slate-600">@teacher.GenderName</td>
            <td class="px-4 py-3 text-slate-600">@(teacher.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(teacher.Phone) ? "-" : teacher.Phone)</td>
            <td class="px-4 py-3 text-slate-600">@(string.IsNullOrEmpty(teacher.Specialization) ? "-" : teacher.Specialization)</td>
            <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-full @(teacher.Status == 1 ? "bg-green-100 text-green-700" : teacher.Status == 2 ? "bg-yellow-100 text-yellow-700" : "bg-red-100 text-red-700")">
                    @teacher.StatusName
                </span>
            </td>
            <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                    <button type="button"
                            class="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all btn-render-modal"
                            title="Sửa"
                            data-url="@Url.Action("_CreateOrEdit", "Teacher", new { id = teacher.Id })"
                            data-title="Sửa giáo viên">
                        <span class="material-symbols-outlined text-base">edit</span>
                    </button>
                    <button type="button"
                            class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all"
                            title="Xóa"
                            onclick="deleteTeacher(@teacher.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(teacher.FullName))')">
                        <span class="material-symbols-outlined text-base">delete</span>
                    </button>
                </div>
            </td>
        </tr>
    }
}
