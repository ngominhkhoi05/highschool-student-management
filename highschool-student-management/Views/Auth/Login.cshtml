@*
    Trang dang nhap - Khong su dung _Layout.cshtml chinh
*@
@model highschool_student_management.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Dang nhap - EduAdmin</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet"/>

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#006b2c",
                        "primary-container": "#00873a",
                        "background": "#f4fcf0",
                        "on-surface": "#171d16",
                        "on-surface-variant": "#3e4a3d",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#eff6ea",
                        "surface-container": "#e9f0e5",
                        "outline": "#6e7b6c",
                        "outline-variant": "#bdcaba",
                        "on-primary": "#ffffff",
                        "error": "#ba1a1a",
                        "on-error-container": "#93000a",
                        "error-container": "#ffdad6",
                        "secondary": "#006d30",
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    fontFamily: {
                        "h1": ["Lexend"],
                        "h2": ["Lexend"],
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-sm": ["Inter"],
                    },
                    fontSize: {
                        "h1": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                        "h2": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}],
                        "body-md": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "body-lg": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "label-sm": ["12px", {"lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "600"}],
                    }
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
    </style>
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-4">

    <!-- Khung dang nhap -->
    <div class="w-full max-w-md">

        <!-- Brand / Logo -->
        <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 bg-primary-container rounded-full flex items-center justify-center mb-4 shadow-sm">
                <span class="material-symbols-outlined text-white text-3xl">school</span>
            </div>
            <h2 class="font-h1 text-h1 text-primary">EduAdmin</h2>
            <p class="font-body-md text-body-md text-outline mt-1">He thong quan ly hoc sinh toan dien</p>
        </div>

        <!-- The dang nhap -->
        <div class="bg-white rounded-xl shadow-[0px_4px_20px_rgba(0,0,0,0.03)] border border-green-100 overflow-hidden">

            <div class="p-8">
                <h1 class="font-h1 text-h1 text-on-surface mb-6 text-center">Dang nhap he thong</h1>

                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="mb-6 p-4 bg-error-container text-on-error-container border border-red-200 rounded-lg flex items-start gap-3">
                        <span class="material-symbols-outlined text-error shrink-0">error</span>
                        <div>
                            <p class="font-label-sm text-label-sm font-bold mb-1">Thong tin khong chinh xac</p>
                            <div class="font-body-md text-body-md opacity-90">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <p>@error.ErrorMessage</p>
                                }
                            </div>
                        </div>
                    </div>
                }

                <form asp-action="Login" method="POST" class="space-y-6">

                    <!-- Truong ten dang nhap -->
                    <div class="space-y-2">
                        <label class="block font-label-sm text-label-sm text-on-surface-variant" asp-for="Username">
                            Ten dang nhap
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-outline text-xl">person</span>
                            </div>
                            <input asp-for="Username"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg font-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
                                   placeholder="Nhap ten dang nhap cua ban"
                                   autocomplete="username"/>
                        </div>
                        <span asp-validation-for="Username" class="text-xs text-error"></span>
                    </div>

                    <!-- Truong mat khau -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="block font-label-sm text-label-sm text-on-surface-variant" asp-for="Password">
                                Mat khau
                            </label>
                            <a class="font-label-sm text-label-sm text-primary hover:underline" href="#">Quen mat khau?</a>
                        </div>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-outline text-xl">lock</span>
                            </div>
                            <input asp-for="Password"
                                   class="w-full pl-10 pr-4 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg font-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
                                   placeholder="Nhap mat khau"
                                   autocomplete="current-password"/>
                        </div>
                        <span asp-validation-for="Password" class="text-xs text-error"></span>
                    </div>

                    <!-- Nut ghi nho dang nhap -->
                    <div class="flex items-center">
                        <input asp-for="RememberMe"
                               class="w-4 h-4 text-primary bg-white border-outline-variant rounded focus:ring-primary focus:ring-offset-2 transition-colors"/>
                        <label class="ml-3 font-body-md text-body-md text-on-surface-variant select-none cursor-pointer" asp-for="RememberMe">
                            Ghi nho dang nhap
                        </label>
                    </div>

                    <!-- Nut dang nhap -->
                    <button type="submit"
                            class="w-full bg-primary text-white font-h2 text-h2 py-3.5 rounded-lg shadow-sm hover:bg-primary-container active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-2">
                        <span>Dang nhap</span>
                        <span class="material-symbols-outlined text-lg">login</span>
                    </button>

                </form>
            </div>

            <!-- Footer -->
            <div class="bg-surface-container-low px-8 py-4 border-t border-green-100">
                <p class="font-label-sm text-label-sm text-center text-outline">
                    &copy; 2026 EduAdmin Management System. Phien ban 1.0.0
                </p>
            </div>

        </div>

        <!-- Ho tro -->
        <div class="mt-8 text-center">
            <div class="inline-flex items-center gap-4">
                <div class="w-10 h-[1px] bg-outline-variant"></div>
                <p class="font-label-sm text-label-sm text-outline-variant uppercase tracking-widest">Ho tro</p>
                <div class="w-10 h-[1px] bg-outline-variant"></div>
            </div>
            <div class="mt-4 flex justify-center gap-6">
                <button class="font-body-md text-body-md text-outline hover:text-primary transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-lg">help</span>
                    Tro giup
                </button>
                <button class="font-body-md text-body-md text-outline hover:text-primary transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-lg">policy</span>
                    Dieu khoan
                </button>
            </div>
        </div>

    </div>

    <!-- Background decoration -->
    <div class="fixed top-0 left-0 -z-10 opacity-10 blur-3xl pointer-events-none">
        <div class="w-[500px] h-[500px] bg-primary rounded-full mix-blend-multiply filter blur-3xl animate-pulse"></div>
    </div>
    <div class="fixed bottom-0 right-0 -z-10 opacity-10 blur-3xl pointer-events-none">
        <div class="w-[400px] h-[400px] bg-secondary rounded-full mix-blend-multiply filter blur-3xl animate-pulse"></div>
    </div>

    <!-- Script xac thuc phia client -->
    <partial name="_ValidationScriptsPartial"/>

</body>
</html>
