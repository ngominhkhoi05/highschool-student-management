@model QuanLyHocSinh.Models.Setting

@{
    var isEdit = Model.Id > 0;
    var pageTitle = isEdit ? "Sửa cấu hình" : "Thêm cấu hình mới";
}

<div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto overflow-hidden">
    <!-- Header -->
    <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-white font-bold text-lg">@pageTitle</h3>
        <button type="button" onclick="closeModal()"
                class="text-white/70 hover:text-white transition-colors">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>
    </div>

    <!-- Form -->
    <form id="formSetting" class="p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />

        <!-- Khoa -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Khóa cài đặt <span class="text-red-500">*</span>
            </label>
            @if (isEdit)
            {
                <input type="text"
                       value="@Model.Key"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm bg-slate-100 text-slate-500 cursor-not-allowed"
                       readonly />
                <input type="hidden" name="Key" value="@Model.Key" />
                <p class="text-xs text-slate-400 mt-1">Khóa không thể thay đổi khi sửa</p>
            }
            else
            {
                <input type="text"
                       name="Key"
                       id="settingKey"
                       value="@Model.Key"
                       placeholder="VD: school_name, pass_score"
                       class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
                <p class="text-xs text-slate-400 mt-1">VD: school_name, logo_url, pass_score, max_students</p>
            }
        </div>

        <!-- Gia tri -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Giá trị
            </label>
            <input type="text"
                   name="Value"
                   id="settingValue"
                   value="@Model.Value"
                   placeholder="Giá trị cấu hình"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Mo ta -->
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
                Mô tả
            </label>
            <input type="text"
                   name="Description"
                   id="settingDescription"
                   value="@Model.Description"
                   placeholder="Mô tả cho cấu hình này"
                   class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-green-500/20 focus:border-green-400 transition-all placeholder:text-slate-300" />
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-2 border-t border-slate-100 mt-4">
            <button type="button"
                    onclick="closeModal()"
                    class="px-5 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-100 rounded-xl transition-colors">
                Hủy bỏ
            </button>
            <button type="button"
                    onclick="submitSettingForm()"
                    class="px-6 py-2.5 text-sm font-semibold text-white bg-green-600 hover:bg-green-700 rounded-xl shadow-sm transition-all">
                @(isEdit ? "Lưu thay đổi" : "Thêm cấu hình")
            </button>
        </div>
    </form>
</div>

<script>
    function closeModal() {
        $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
    }

    function submitSettingForm() {
        var key = $('#settingKey').val();

        if (!key || !key.trim()) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: 'Khóa cài đặt không được để trống.',
                confirmButtonColor: '#006b2c'
            });
            return;
        }

        var formData = $('#formSetting').serialize();

        $.ajax({
            url: '@Url.Action("SaveSetting", "Setting")',
            type: 'POST',
            data: formData,
            success: function(result) {
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    }).then(function() {
                        closeModal();
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: result.message,
                        confirmButtonColor: '#006b2c'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                    confirmButtonColor: '#006b2c'
                });
            }
        });
    }
</script>
