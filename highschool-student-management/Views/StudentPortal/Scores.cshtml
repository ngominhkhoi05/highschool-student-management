@model highschool_student_management.ViewModels.StudentScoresViewModel

@{
    ViewData["Title"] = "Bảng điểm";
}

<div class="p-6 space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-green-600">grade</span>
            <div>
                <h1 class="text-xl font-bold text-slate-800">Bảng điểm</h1>
                <p class="text-sm text-slate-500">@Model.FullName (@Model.StudentCode)</p>
            </div>
        </div>
        <a asp-action="Index" class="text-sm text-green-600 hover:text-green-700 font-medium">Quay lai</a>
    </div>

    <!-- Chọn học kỳ -->
    <div class="flex flex-wrap gap-2">
        @foreach (var sem in Model.Semesters)
        {
            <a asp-action="Scores" asp-route-semesterId="@sem.Id"
               class="px-4 py-2 rounded-lg text-sm font-medium transition-all
                      @(sem.Id == Model.CurrentSemesterId ? "bg-green-600 text-white" : "bg-green-50 text-green-700 hover:bg-green-100")">
                @sem.Name
            </a>
        }
    </div>

    <!-- Bang diem -->
    @if (!Model.Scores.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300">search_off</span>
            <p class="mt-3 text-slate-500 font-medium">Chưa có điểm trong học kỳ này</p>
        </div>
    }
    else
    {
        var subjects = Model.Scores.GroupBy(s => s.SubjectId).OrderBy(g => g.Key);
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-green-600 text-white">
                            <th class="px-4 py-3 text-left font-semibold w-8">STT</th>
                            <th class="px-4 py-3 text-left font-semibold">Môn học</th>
                            @{
                                var scoreTypes = Model.Scores.Select(s => s.ScoreTypeName).Distinct().OrderBy(st => st).ToList();
                                foreach (var st in scoreTypes)
                                {
                                    <th class="px-4 py-3 text-center font-semibold whitespace-nowrap">@st</th>
                                }
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{ var stt = 1; }
                        @foreach (var subject in subjects)
                        {
                            var rowClass = stt % 2 == 0 ? "bg-green-50" : "bg-white";
                            <tr class="@rowClass hover:bg-green-100 transition-colors">
                                <td class="px-4 py-3 text-slate-500">@stt</td>
                                <td class="px-4 py-3 font-medium text-slate-700">@subject.First().SubjectName</td>
                                @foreach (var scoreType in scoreTypes)
                                {
                                    var score = subject.FirstOrDefault(s => s.ScoreTypeName == scoreType);
                                    var scoreClass = "";
                                    if (score?.ScoreValue != null)
                                    {
                                        var v = (double)score.ScoreValue;
                                        if (v >= 8.0) scoreClass = "text-green-700 font-bold";
                                        else if (v < 5.0) scoreClass = "text-red-600 font-bold";
                                        else scoreClass = "text-slate-700";
                                    }
                                    <td class="px-4 py-3 text-center @scoreClass">
                                        @(score?.ScoreValue?.ToString("F2") ?? "-")
                                    </td>
                                }
                            </tr>
                            stt++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
