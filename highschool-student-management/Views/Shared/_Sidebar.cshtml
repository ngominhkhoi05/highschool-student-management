@*
    Sidebar - Thanh dieu huong ben trai
    Chua menu danh sach theo phan quyen: Admin, Teacher, Student/Parent
*@
@{ Layout = null; }

@{
    var userName = Context.User?.Identity?.Name ?? "User";
    var userRole = Context.User?.IsInRole("Admin") == true ? "Admin"
                 : Context.User?.IsInRole("Teacher") == true ? "Giao Vien"
                 : Context.User?.IsInRole("Student") == true ? "Hoc Sinh"
                 : Context.User?.IsInRole("Parent") == true ? "Phu Huynh"
                 : "Unknown";
}

<!-- Sidebar: Cau truc co dinh 280px -->
<aside id="sidebar" class="fixed left-0 top-0 h-full w-[280px] bg-white border-r border-green-100 flex flex-col z-40 shadow-[4px_0_20px_rgba(0,0,0,0.03)] font-['Lexend'] text-sm antialiased">

    <div class="flex flex-col h-full py-6">

        <!-- Brand Logo -->
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-container rounded-xl flex items-center justify-center text-white">
                    <span class="material-symbols-outlined">school</span>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-green-700 tracking-tight">EduAdmin</h1>
                    <p class="text-[10px] text-slate-500 uppercase tracking-widest font-semibold">He thong quan ly</p>
                </div>
            </div>
        </div>

        <!-- Navigation Menu -->
        <div class="flex-1 overflow-y-auto sidebar-scroll px-3">

            @* ===== NHOM ADMIN ===== *@
            @if (Context.User?.IsInRole("Admin") == true)
            {
                <!-- Quan tri he thong -->
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Quan tri he thong</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 border-l-4 border-green-600 bg-green-50 text-green-700 font-semibold px-4 py-3 cursor-pointer active:scale-[0.98] transition-all duration-200"
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Bang dieu khien</span>
                        </a>

                        <!-- He thong -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">He thong</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="SchoolYears" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">calendar_today</span>
                                <span>Nam hoc</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Subjects" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">book</span>
                                <span>Mon hoc</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Settings" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">settings</span>
                                <span>Cau hinh</span>
                            </a>
                        </div>

                        <!-- Nhan su -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Nhan su</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Teachers" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">person_apron</span>
                                <span>Giao vien</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Students" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">group</span>
                                <span>Hoc sinh</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Parents" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">family_restroom</span>
                                <span>Phu huynh</span>
                            </a>
                        </div>

                        <!-- Hoc vu -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Hoc vu</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Classes" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">meeting_room</span>
                                <span>Lop hoc</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="TeacherClasses" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">assignment</span>
                                <span>Phan cong</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Notifications" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">campaign</span>
                                <span>Thong bao</span>
                            </a>
                        </div>

                    </nav>
                </div>
            }

            @* ===== NHOM GIAO VIEN ===== *@
            @if (Context.User?.IsInRole("Teacher") == true)
            {
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Giang day &amp; Chu nhiem</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Bang dieu khien</span>
                        </a>

                        <!-- Cong tac giang day -->
                        <div class="space-y-1">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Cong tac giang day</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Scores" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">assignment</span>
                                <span>So diem</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Attendances" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">how_to_reg</span>
                                <span>Diem danh</span>
                            </a>
                        </div>

                        <!-- Cong tac chu nhiem -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Cong tac chu nhiem</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Classes" asp-action="MyClass">
                                <span class="material-symbols-outlined text-lg">meeting_room</span>
                                <span>Lop chu nhiem</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Violations" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">report</span>
                                <span>Nep le</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="ConductScores" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">stars</span>
                                <span>Hanh kiem</span>
                            </a>
                        </div>

                    </nav>
                </div>
            }

            @* ===== NHOM HOC SINH / PHU HUYNH ===== *@
            @if (Context.User?.IsInRole("Student") == true || Context.User?.IsInRole("Parent") == true)
            {
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Ca nhan &amp; Thong bao</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Bang dieu khien</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="SemesterResults" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">grade</span>
                            <span>Ket qua hoc tap</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Attendances" asp-action="MyAttendance">
                            <span class="material-symbols-outlined text-lg">how_to_reg</span>
                            <span>Diem danh</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Notifications" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">notifications</span>
                            <span>Thong bao</span>
                        </a>

                    </nav>
                </div>
            }

        </div>

        <!-- Sidebar Footer: Nut dang xuat -->
        <div class="px-3 pt-4 border-t border-slate-100">
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="w-full flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-red-50 hover:text-red-600 transition-all duration-200 rounded-lg">
                    <span class="material-symbols-outlined text-lg">logout</span>
                    <span class="font-medium">Dang xuat</span>
                </button>
            </form>
        </div>

    </div>

</aside>
