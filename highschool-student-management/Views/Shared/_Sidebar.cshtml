@*
    Sidebar - Thanh điều hướng bên trái
    Chứa menu danh sách theo phân quyền: Admin, Teacher, Student/Parent
*@
@{ Layout = null; }

@{
    var userName = Context.User?.Identity?.Name ?? "User";
    var userRole = Context.User?.IsInRole("Admin") == true ? "Admin"
                 : Context.User?.IsInRole("Teacher") == true ? "Giáo viên"
                 : Context.User?.IsInRole("Student") == true ? "Học sinh"
                 : Context.User?.IsInRole("Parent") == true ? "Phụ huynh"
                 : "Unknown";
}

<!-- Sidebar: Cấu trúc cố định 280px -->
<aside id="sidebar" class="fixed left-0 top-0 h-full w-[280px] bg-white border-r border-green-100 flex flex-col z-40 shadow-[4px_0_20px_rgba(0,0,0,0.03)] font-['Lexend'] text-sm antialiased">

    <div class="flex flex-col h-full py-6">

        <!-- Brand Logo -->
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-container rounded-xl flex items-center justify-center text-white">
                    <span class="material-symbols-outlined">school</span>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-green-700 tracking-tight">EduAdmin</h1>
                    <p class="text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Hệ thống quản lý</p>
                </div>
            </div>
        </div>

        <!-- Navigation Menu -->
        <div class="flex-1 overflow-y-auto sidebar-scroll px-3">

            @* ===== NHÓM ADMIN ===== *@
            @if (Context.User?.IsInRole("Admin") == true)
            {
                <!-- Quản trị hệ thống -->
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Quản trị hệ thống</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 border-l-4 border-green-600 bg-green-50 text-green-700 font-semibold px-4 py-3 cursor-pointer active:scale-[0.98] transition-all duration-200"
                           asp-area="" asp-controller="Dashboard" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Bảng điều khiển</span>
                        </a>

                        <!-- He thong -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Hệ thống</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="SchoolYear" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">calendar_today</span>
                                <span>Năm học</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Subject" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">book</span>
                                <span>Môn học</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Class" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">class</span>
                                <span>Lớp học</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="ScoreType" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">score</span>
                                <span>Loại điểm</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="ViolationType" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">gavel</span>
                                <span>Loại vi phạm</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Setting" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">settings</span>
                                <span>Cấu hình</span>
                            </a>
                        </div>

                        <!-- Quan ly nguoi dung -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Quản lý người dùng</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Teacher" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">school</span>
                                <span>Giáo viên</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Student" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">groups</span>
                                <span>Học sinh</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Parent" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">family_restroom</span>
                                <span>Phụ huynh</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Account" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">manage_accounts</span>
                                <span>Tài khoản</span>
                            </a>
                        </div>

                        <!-- Giao vien bo mon -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Giáo viên bộ môn</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="TeacherAttendance" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">how_to_reg</span>
                                <span>Sổ điểm danh</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="TeacherScore" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">grade</span>
                                <span>Sổ điểm</span>
                            </a>
                        </div>

                    </nav>
                </div>
            }

            @* ===== NHÓM GIÁO VIÊN ===== *@
            @if (Context.User?.IsInRole("Teacher") == true)
            {
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Giảng dạy &amp; Chủ nhiệm</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Bảng điều khiển</span>
                        </a>

                        <!-- Công tác giảng dạy -->
                        <div class="space-y-1">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Công tác giảng dạy</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="TeacherScore" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">assignment</span>
                                <span>Sổ điểm</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="TeacherAttendance" asp-action="Index">
                                <span class="material-symbols-outlined text-lg">how_to_reg</span>
                                <span>Điểm danh</span>
                            </a>
                        </div>

                        <!-- Công tác chủ nhiệm -->
                        <div class="space-y-1 mt-2">
                            <p class="px-4 py-2 text-xs font-semibold text-slate-500">Công tác chủ nhiệm</p>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Homeroom" asp-action="MyClass">
                                <span class="material-symbols-outlined text-lg">meeting_room</span>
                                <span>Lớp chủ nhiệm</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Homeroom" asp-action="Violations">
                                <span class="material-symbols-outlined text-lg">report</span>
                                <span>Vi phạm</span>
                            </a>

                            <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                               asp-area="" asp-controller="Homeroom" asp-action="ConductScores">
                                <span class="material-symbols-outlined text-lg">stars</span>
                                <span>Hạnh kiểm</span>
                            </a>
                        </div>

                    </nav>
                </div>
            }

            @* ===== NHOM HOC SINH ===== *@
            @if (Context.User?.IsInRole("Student") == true)
            {
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Tra cứu</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 border-l-4 border-green-600 bg-green-50 text-green-700 font-semibold px-4 py-3 cursor-pointer transition-all duration-200"
                           asp-area="" asp-controller="StudentPortal" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Tổng quan</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="StudentPortal" asp-action="Scores">
                            <span class="material-symbols-outlined text-lg">grade</span>
                            <span>Bảng điểm</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="StudentPortal" asp-action="Attendances">
                            <span class="material-symbols-outlined text-lg">how_to_reg</span>
                            <span>Điểm danh</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="StudentPortal" asp-action="Conduct">
                            <span class="material-symbols-outlined text-lg">stars</span>
                            <span>Hạnh kiểm</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Notification" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">notifications</span>
                            <span>Thông báo</span>
                        </a>
                    </nav>
                </div>
            }

            @* ===== NHOM PHU HUYNH ===== *@
            @if (Context.User?.IsInRole("Parent") == true)
            {
                <div class="mb-6">
                    <p class="px-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Tra cứu</p>
                    <nav class="space-y-1">

                        <a class="flex items-center gap-3 border-l-4 border-green-600 bg-green-50 text-green-700 font-semibold px-4 py-3 cursor-pointer transition-all duration-200"
                           asp-area="" asp-controller="ParentPortal" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">dashboard</span>
                            <span>Tổng quan</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="ParentPortal" asp-action="Scores">
                            <span class="material-symbols-outlined text-lg">grade</span>
                            <span>Bảng điểm</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="ParentPortal" asp-action="Attendances">
                            <span class="material-symbols-outlined text-lg">how_to_reg</span>
                            <span>Điểm danh</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="ParentPortal" asp-action="Conduct">
                            <span class="material-symbols-outlined text-lg">stars</span>
                            <span>Hạnh kiểm</span>
                        </a>

                        <a class="flex items-center gap-3 text-slate-500 px-4 py-2 hover:bg-green-50 hover:text-green-600 transition-all duration-200"
                           asp-area="" asp-controller="Notification" asp-action="Index">
                            <span class="material-symbols-outlined text-lg">notifications</span>
                            <span>Thông báo</span>
                        </a>
                    </nav>
                </div>
            }

        </div>

        <!-- Sidebar Footer: Nút đăng xuất -->
        <div class="px-3 pt-4 border-t border-slate-100">
            <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-3 text-slate-500 px-4 py-3 hover:bg-red-50 hover:text-red-600 transition-all duration-200 rounded-lg">
                    <span class="material-symbols-outlined text-lg">logout</span>
                    <span class="font-medium">Đăng xuất</span>
                </button>
            </form>
        </div>

    </div>

</aside>
