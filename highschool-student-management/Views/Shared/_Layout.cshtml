<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - EduAdmin</title>

    <!-- Google Fonts: Lexend & Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>

    <!-- Google Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- FontAwesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#00873a",
                        "primary": "#006b2c",
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    fontFamily: {
                        "display-lg": ["Lexend"],
                        "h2": ["Lexend"],
                        "label-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "h1": ["Lexend"],
                        "body-md": ["Inter"]
                    },
                    fontSize: {
                        "display-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "700"}],
                        "h2": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "600"}],
                        "body-lg": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "h1": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                        "body-md": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }
        /* Thanh cuộn custom cho sidebar */
        .sidebar-scroll::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
        /* Ẩn sidebar trên màn hình nhỏ */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }
            #sidebar.sidebar-open {
                transform: translateX(0);
            }
            #topbar {
                margin-left: 0 !important;
            }
            #main-content {
                margin-left: 0 !important;
            }
        }
    </style>
</head>
<body class="bg-[#f4fcf0] text-slate-800 antialiased">

    <!-- Sidebar: Partial view cho thanh điều hướng bên trái -->
    @if (Context.User?.Identity?.IsAuthenticated == true)
    {
        <partial name="_Sidebar"/>
    }

    <!-- Topbar: Partial view cho thanh điều hướng phía trên -->
    @if (Context.User?.Identity?.IsAuthenticated == true)
    {
        <partial name="_Topbar"/>
    }

    <!-- Main Content: Nội dung chính của trang -->
    @{
        var mainMarginClass = Context.User?.Identity?.IsAuthenticated == true ? "ml-[280px]" : "";
    }
    <main id="main-content" class="@mainMarginClass p-8 min-h-[calc(100vh-64px)] bg-[#f4fcf0]">
        @RenderBody()
    </main>

    <!-- Modal Container: Nơi chứa popup CRUD từ AJAX -->
    <div class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 backdrop-blur-sm px-4"
         id="modalContainer">
        <!-- Nội dung partial view sẽ được load vào đây qua AJAX -->
    </div>

    <!-- Scripts Area -->
    <script>
        $(document).ready(function() {

            // === Nút toggle sidebar trên mobile ===
            $('#btnToggleSidebar').on('click', function() {
                $('#sidebar').toggleClass('sidebar-open');
            });

            // === Đóng sidebar khi click ra ngoài trên mobile ===
            $(document).on('click', function(e) {
                if ($(window).width() <= 768) {
                    if (!$(e.target).closest('#sidebar').length && !$(e.target).closest('#btnToggleSidebar').length) {
                        $('#sidebar').removeClass('sidebar-open');
                    }
                }
            });

            // === SweetAlert2 logout ===
            $(document).on('click', '.btn-logout', function(e) {
                e.preventDefault();
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Xác nhận đăng xuất',
                    text: 'Bạn có chắc chắn muốn đăng xuất không?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#006b2c',
                    cancelButtonColor: '#94a3b8',
                    confirmButtonText: 'Có, đăng xuất',
                    cancelButtonText: 'Hủy',
                    reverseButtons: true
                }).then(function(result) {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // === Bắt sự kiện mở modal cho các nút có class .btn-render-modal ===
            $(document).on('click', '.btn-render-modal', function(e) {
                e.preventDefault();
                var url = $(this).data('url');
                var title = $(this).data('title') || 'Chi tiết';

                if (!url) {
                    // Nếu không có url, chỉ hiển thị mockup (dùng cho mẫu)
                    Swal.fire({
                        title: 'Đang tải dữ liệu...',
                        allowOutsideClick: false,
                        didOpen: function() {
                            Swal.showLoading();
                        }
                    });
                    setTimeout(function() {
                        Swal.close();
                    }, 600);
                    return;
                }

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function(data) {
                        $('#modalContainer')
                            .html(data)
                            .removeClass('hidden')
                            .addClass('flex')
                            .hide()
                            .fadeIn();
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi',
                            text: 'Không thể tải nội dung. Vui lòng thử lại.',
                            confirmButtonColor: '#006b2c'
                        });
                    }
                });
            });

            // === Đóng modal khi click nút close hoặc ra ngoài ===
            $(document).on('click', '.btn-modal-close', function() {
                $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
            });

            $(window).on('click', function(e) {
                if ($(e.target).is('#modalContainer')) {
                    $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                }
            });

            // === Bắt sự kiện form submit trong modal (SweetAlert2) ===
            $(document).on('submit', '#modalForm', function(e) {
                e.preventDefault();
                var form = $(this);
                var url = form.attr('action') || window.location.href;
                var formData = form.serialize();

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: formData,
                    success: function(result) {
                        if (result.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: result.message || 'Dữ liệu đã được lưu.',
                                confirmButtonColor: '#006b2c'
                            }).then(function() {
                                $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                                if (result.reload) {
                                    location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi',
                                text: result.message || 'Đã xảy ra lỗi. Vui lòng thử lại.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi',
                            text: 'Không thể lưu dữ liệu. Vui lòng thử lại.',
                            confirmButtonColor: '#006b2c'
                        });
                    }
                });
            });

        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
