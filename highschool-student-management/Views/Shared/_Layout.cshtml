<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - EduAdmin</title>

    <!-- Google Fonts: Lexend & Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- FontAwesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#00873a",
                        "primary": "#006b2c",
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    fontFamily: {
                        "display-lg": ["Lexend"],
                        "h2": ["Lexend"],
                        "label-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "h1": ["Lexend"],
                        "body-md": ["Inter"]
                    },
                    fontSize: {
                        "display-lg": ["32px", {"lineHeight": "1.2", "fontWeight": "700"}],
                        "h2": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "1", "letterSpacing": "0.02em", "fontWeight": "600"}],
                        "body-lg": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "h1": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                        "body-md": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Lexend', sans-serif;
        }
        /* Thanh cuon custom cho sidebar */
        .sidebar-scroll::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
        /* An sidebar tren man hinh nho */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }
            #sidebar.sidebar-open {
                transform: translateX(0);
            }
            #topbar {
                margin-left: 0 !important;
            }
            #main-content {
                margin-left: 0 !important;
            }
        }
    </style>
</head>
<body class="bg-[#f4fcf0] text-slate-800 antialiased">

    <!-- Sidebar: Partial view cho thanh dieu huong ben trai -->
    <partial name="_Sidebar"/>

    <!-- Topbar: Partial view cho thanh dieu huong phia tren -->
    <partial name="_Topbar" view-data='new ViewDataDictionary(ViewData) { { "Title", ViewData["Title"] ?? "Bang dieu khien" }, { "NotifCount", ViewData["NotifCount"] ?? 0 } }'/>

    <!-- Main Content: Noi dung chinh cua trang -->
    <main id="main-content" class="ml-[280px] p-8 min-h-[calc(100vh-64px)] bg-[#f4fcf0]">
        @RenderBody()
    </main>

    <!-- Modal Container: Noi chua popup CRUD tu AJAX -->
    <div class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 backdrop-blur-sm px-4"
         id="modalContainer">
        <!-- Noi dung partial view se duoc load vao day qua AJAX -->
    </div>

    <!-- Scripts Area -->
    <script>
        $(document).ready(function() {

            // === Nut toggle sidebar tren mobile ===
            $('#btnToggleSidebar').on('click', function() {
                $('#sidebar').toggleClass('sidebar-open');
            });

            // === Dong sidebar khi click ra ngoai tren mobile ===
            $(document).on('click', function(e) {
                if ($(window).width() <= 768) {
                    if (!$(e.target).closest('#sidebar').length && !$(e.target).closest('#btnToggleSidebar').length) {
                        $('#sidebar').removeClass('sidebar-open');
                    }
                }
            });

            // === Bat su kien mo modal cho cac nut co class .btn-render-modal ===
            $(document).on('click', '.btn-render-modal', function(e) {
                e.preventDefault();
                var url = $(this).data('url');
                var title = $(this).data('title') || 'Chi tiet';

                if (!url) {
                    // Neu khong co url, chi hien thi mockup (dung cho mau)
                    Swal.fire({
                        title: 'Dang tai du lieu...',
                        allowOutsideClick: false,
                        didOpen: function() {
                            Swal.showLoading();
                        }
                    });
                    setTimeout(function() {
                        Swal.close();
                    }, 600);
                    return;
                }

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function(data) {
                        $('#modalContainer')
                            .html(data)
                            .removeClass('hidden')
                            .addClass('flex')
                            .hide()
                            .fadeIn();
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Loi',
                            text: 'Khong the tai noi dung. Vui long thu lai.',
                            confirmButtonColor: '#006b2c'
                        });
                    }
                });
            });

            // === Dong modal khi click nut close hoac ra ngoai ===
            $(document).on('click', '.btn-modal-close', function() {
                $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
            });

            $(window).on('click', function(e) {
                if ($(e.target).is('#modalContainer')) {
                    $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                }
            });

            // === Bat su kien form submit trong modal (SweetAlert2) ===
            $(document).on('submit', '#modalForm', function(e) {
                e.preventDefault();
                var form = $(this);
                var url = form.attr('action') || window.location.href;
                var formData = form.serialize();

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: formData,
                    success: function(result) {
                        if (result.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thanh cong!',
                                text: result.message || 'Du lieu da duoc luu.',
                                confirmButtonColor: '#006b2c'
                            }).then(function() {
                                $('#modalContainer').fadeOut().addClass('hidden').removeClass('flex');
                                if (result.reload) {
                                    location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Loi',
                                text: result.message || 'Da xay ra loi. Vui long thu lai.',
                                confirmButtonColor: '#006b2c'
                            });
                        }
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Loi',
                            text: 'Khong the luu du lieu. Vui long thu lai.',
                            confirmButtonColor: '#006b2c'
                        });
                    }
                });
            });

        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
