@model List<highschool_student_management.ViewModels.ViolationIndexViewModel>

@if (Model == null || !Model.Any())
{
    <div class="p-12 text-center text-slate-400">
        <span class="material-symbols-outlined text-5xl">check_circle</span>
        <p class="mt-3 text-slate-500 font-medium">Chua co vi pham nao</p>
        <p class="text-sm mt-1">Danh sach vi pham trong hoc ky nay se hien thi o day.</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-red-50 text-red-700">
                <tr>
                    <th class="px-4 py-3 text-left font-semibold">Ngay</th>
                    <th class="px-4 py-3 text-left font-semibold">Ma HS</th>
                    <th class="px-4 py-3 text-left font-semibold">Ho va ten</th>
                    <th class="px-4 py-3 text-left font-semibold">Loai vi pham</th>
                    <th class="px-4 py-3 text-center font-semibold">Muc do</th>
                    <th class="px-4 py-3 text-left font-semibold">Mo ta</th>
                    <th class="px-4 py-3 text-center font-semibold">Hanh dong</th>
                    <th class="px-4 py-3 text-center font-semibold w-16"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var severityClass = v.Severity switch
                    {
                        1 => "bg-yellow-100 text-yellow-700",
                        2 => "bg-orange-100 text-orange-700",
                        3 => "bg-red-100 text-red-700",
                        _ => "bg-slate-100 text-slate-600"
                    };
                    var severityText = v.Severity switch
                    {
                        1 => "Nhe",
                        2 => "Trung binh",
                        3 => "Nang",
                        _ => "-"
                    };
                    var actionText = v.ActionTaken switch
                    {
                        1 => "Nhac nho",
                        2 => "Phat lao dong",
                        3 => "Moi phu huynh",
                        4 => "Ky luat",
                        _ => "-"
                    };
                    <tr class="odd:bg-white even:bg-red-50/20 hover:bg-red-50/40 transition-colors" data-id="@v.Id">
                        <td class="px-4 py-3 text-slate-600">@v.ViolationDate.ToString("dd/MM/yyyy")</td>
                        <td class="px-4 py-3 font-medium text-green-700">@v.StudentCode</td>
                        <td class="px-4 py-3 font-semibold text-slate-800">@v.StudentName</td>
                        <td class="px-4 py-3 text-slate-600">@v.ViolationTypeName</td>
                        <td class="px-4 py-3 text-center">
                            <span class="px-2 py-1 rounded-full text-xs font-bold @severityClass">@severityText</span>
                        </td>
                        <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">@(v.Description ?? "-")</td>
                        <td class="px-4 py-3 text-center text-xs text-slate-500">@actionText</td>
                        <td class="px-4 py-3 text-center">
                            <button onclick="deleteViolation(@v.Id)"
                                    class="text-red-400 hover:text-red-600 transition-colors p-1 rounded hover:bg-red-50"
                                    title="Xoa">
                                <span class="material-symbols-outlined text-lg">delete</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
