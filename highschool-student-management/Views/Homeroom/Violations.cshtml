@model List<highschool_student_management.ViewModels.ViolationIndexViewModel>

@{
    var semesters = ViewData["Semesters"] as List<highschool_student_management.ViewModels.SemesterDropdown> ?? new();
    var violationTypes = ViewData["ViolationTypes"] as List<highschool_student_management.ViewModels.ViolationTypeDropdown> ?? new();
    var students = ViewData["Students"] as List<highschool_student_management.ViewModels.StudentDropdown> ?? new();
    var selectedSemesterId = semesters.FirstOrDefault()?.Id ?? 0;
    var classId = (int)(ViewData["ClassId"] ?? 0);
    var className = ViewData["ClassName"]?.ToString() ?? "";
    ViewData["Title"] = "Theo dõi vi phạm";
}

<div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-red-500">report</span>
            <div>
                <h2 class="text-xl font-bold text-slate-800">Theo dõi vi phạm</h2>
                <p class="text-sm text-slate-500">@className</p>
            </div>
        </div>
        <button onclick="openAddViolationModal()"
                class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Thêm vi phạm
        </button>
    </div>

    <!-- Bo loc hoc ky -->
    <div class="bg-white rounded-xl p-4 mb-4 flex flex-wrap gap-3 items-center border border-green-100">
        <label class="text-sm font-semibold text-slate-600">Học kỳ:</label>
        @foreach (var sem in semesters)
        {
            <button onclick="loadViolationsBySemester(@sem.Id)"
                    data-semester-id="@sem.Id"
                    class="semester-btn px-4 py-2 rounded-lg text-sm font-medium transition-all @(sem.Id == selectedSemesterId ? "bg-green-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-green-50")">
                @sem.Name
            </button>
        }
    </div>

    <!-- Bang vi pham -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-3 border-b border-green-100 flex items-center gap-3 bg-slate-50/50">
            <div class="relative flex-1 max-w-xs">
                <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400 text-base">search</span>
                <input type="text"
                       id="searchInput"
                       placeholder="Tìm kiếm theo tên hoặc mã học sinh..."
                       class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 transition-all placeholder:text-slate-300" />
            </div>
            <span id="searchCount" class="text-xs text-slate-400"></span>
            <button id="btnClearSearch"
                    type="button"
                    class="hidden px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-slate-100 rounded-lg transition-all">
                Xóa lọc
            </button>
        </div>

        <div id="violationListContainer">
            @if (Model == null || !Model.Any())
            {
                <div class="p-12 text-center text-slate-400">
                    <span class="material-symbols-outlined text-5xl">check_circle</span>
                    <p class="mt-3 text-slate-500 font-medium">Chưa có vi phạm nào</p>
                    <p class="text-sm mt-1">Danh sách vi phạm trong học kỳ này sẽ hiển thị ở đây.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-red-50 text-red-700">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold">Ngày</th>
                                <th class="px-4 py-3 text-left font-semibold">Mã HS</th>
                                <th class="px-4 py-3 text-left font-semibold">Họ và tên</th>
                                <th class="px-4 py-3 text-left font-semibold">Loại vi phạm</th>
                                <th class="px-4 py-3 text-center font-semibold">Mức độ</th>
                                <th class="px-4 py-3 text-left font-semibold">Mô tả</th>
                                <th class="px-4 py-3 text-center font-semibold">Hành động</th>
                                <th class="px-4 py-3 text-center font-semibold w-16"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model)
                            {
                                var severityClass = v.Severity switch
                                {
                                    1 => "bg-yellow-100 text-yellow-700",
                                    2 => "bg-orange-100 text-orange-700",
                                    3 => "bg-red-100 text-red-700",
                                    _ => "bg-slate-100 text-slate-600"
                                };
                                var severityText = v.Severity switch
                                {
                                    1 => "Nhẹ",
                                    2 => "Trung bình",
                                    3 => "Nặng",
                                    _ => "-"
                                };
                                var actionText = v.ActionTaken switch
                                {
                                    1 => "Nhắc nhở",
                                    2 => "Phạt lao động",
                                    3 => "Mời phụ huynh",
                                    4 => "Kỷ luật",
                                    _ => "-"
                                };
                                <tr class="violation-row odd:bg-white even:bg-red-50/20 hover:bg-red-50/40 transition-colors"
                                    data-id="@v.Id"
                                    data-code="@v.StudentCode.ToLower()"
                                    data-name="@v.StudentName.ToLower()">
                                    <td class="px-4 py-3 text-slate-600">@v.ViolationDate.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3 font-medium text-green-700">@v.StudentCode</td>
                                    <td class="px-4 py-3 font-semibold text-slate-800">@v.StudentName</td>
                                    <td class="px-4 py-3 text-slate-600">@v.ViolationTypeName</td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="px-2 py-1 rounded-full text-xs font-bold @severityClass">@severityText</span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">@(v.Description ?? "-")</td>
                                    <td class="px-4 py-3 text-center text-xs text-slate-500">@actionText</td>
                                    <td class="px-4 py-3 text-center">
                                        <button onclick="deleteViolation(@v.Id)"
                                                class="text-red-400 hover:text-red-600 transition-colors p-1 rounded hover:bg-red-50"
                                                title="Xóa">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Popup thêm vi phạm -->
<div id="addViolationModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
        <div class="bg-red-600 px-6 py-4 flex items-center justify-between">
            <h3 class="text-white font-bold text-lg flex items-center gap-2">
                <span class="material-symbols-outlined">report</span>
                Thêm vi phạm
            </h3>
            <button onclick="closeAddViolationModal()" class="text-white/80 hover:text-white transition-colors">
                <span class="material-symbols-outlined text-2xl">close</span>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Học kỳ <span class="text-red-500">*</span></label>
                <select id="vSemesterId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chọn học kỳ --</option>
                    @foreach (var sem in semesters)
                    {
                        <option value="@sem.Id">@sem.Name</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Học sinh <span class="text-red-500">*</span></label>
                <select id="vStudentId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chọn học sinh --</option>
                    @foreach (var s in students)
                    {
                        <option value="@s.StudentId">@s.StudentCode - @s.FullName</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Loại vi phạm <span class="text-red-500">*</span></label>
                <select id="vTypeId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chọn loại vi phạm --</option>
                    @foreach (var vt in violationTypes)
                    {
                        var sevText = vt.Severity switch { 1 => "Nhẹ", 2 => "Trung bình", _ => "Nặng" };
                        <option value="@vt.Id" data-severity="@vt.Severity" data-deduct="@vt.DeductPoints">@vt.Name (@sevText, -@vt.DeductPoints điểm)</option>
                    }
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-600 mb-2">Ngày vi phạm <span class="text-red-500">*</span></label>
                    <input type="date" id="vDate"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-600 mb-2">Hành động xử lý</label>
                    <select id="vAction"
                            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                        <option value="">-- Chọn --</option>
                        <option value="1">Nhắc nhở</option>
                        <option value="2">Phạt lao động</option>
                        <option value="3">Mời phụ huynh</option>
                        <option value="4">Kỷ luật</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Mô tả</label>
                <textarea id="vDesc"
                          rows="3"
                          placeholder="Mô tả chi tiết vi phạm..."
                          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 placeholder:text-slate-300"></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button onclick="closeAddViolationModal()"
                        class="flex-1 px-4 py-2.5 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-semibold rounded-xl transition-all">
                    Đóng
                </button>
                <button onclick="saveViolation()"
                        class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">save</span>
                    Ghi nhận
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Real-time search for violations
    (function() {
        var searchTimer = null;

        function doFilter(term) {
            term = term.toLowerCase().trim();
            var rows = document.querySelectorAll('.violation-row');
            var visibleCount = 0;

            rows.forEach(function(row) {
                var name = row.getAttribute('data-name') || '';
                var code = row.getAttribute('data-code') || '';
                var matches = !term || name.includes(term) || code.includes(term);
                row.style.display = matches ? '' : 'none';
                if (matches) visibleCount++;
            });

            var countEl = document.getElementById('searchCount');
            var clearBtn = document.getElementById('btnClearSearch');
            if (term) {
                countEl.textContent = visibleCount + ' vi phạm';
                clearBtn.classList.remove('hidden');
            } else {
                countEl.textContent = '';
                clearBtn.classList.add('hidden');
            }
        }

        document.getElementById('searchInput').addEventListener('input', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                doFilter(document.getElementById('searchInput').value);
            }, 300);
        });

        document.getElementById('btnClearSearch').addEventListener('click', function() {
            document.getElementById('searchInput').value = '';
            doFilter('');
        });
    })();

    function openAddViolationModal() {
        var activeBtn = document.querySelector('.semester-btn.bg-green-600');
        if (activeBtn) {
            var activeSemesterId = activeBtn.getAttribute('data-semester-id');
            if (activeSemesterId) {
                $('#vSemesterId').val(activeSemesterId);
            }
        }
        $('#addViolationModal').removeClass('hidden').addClass('flex');
    }

    function closeAddViolationModal() {
        $('#addViolationModal').removeClass('flex').addClass('hidden');
        document.getElementById('vSemesterId').value = '';
        document.getElementById('vStudentId').value = '';
        document.getElementById('vTypeId').value = '';
        document.getElementById('vAction').value = '';
        document.getElementById('vDesc').value = '';
        document.getElementById('vDate').value = '@DateTime.Now.ToString("yyyy-MM-dd")';
    }

    function saveViolation() {
        var semesterId = parseInt($('#vSemesterId').val()) || 0;
        var studentId = parseInt($('#vStudentId').val()) || 0;
        var typeId = parseInt($('#vTypeId').val()) || 0;
        var date = $('#vDate').val();
        var action = parseInt($('#vAction').val()) || 0;
        var desc = $('#vDesc').val();

        if (!semesterId) {
            Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng chọn học kỳ.', confirmButtonColor: '#dc2626' });
            return;
        }
        if (!studentId || !typeId || !date) {
            Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng chọn học sinh, loại vi phạm và ngày vi phạm.', confirmButtonColor: '#dc2626' });
            return;
        }

        $.ajax({
            url: '@Url.Action("CreateViolation", "Homeroom")',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: JSON.stringify({
                studentId: studentId,
                violationTypeId: typeId,
                semesterId: semesterId,
                violationDate: date,
                description: desc || null,
                actionTaken: action > 0 ? action : null
            }),
            success: function(result) {
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'Thành công!', text: result.message, confirmButtonColor: '#006b2c' }).then(function() {
                        closeAddViolationModal();
                        loadViolationsBySemester(semesterId);
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: result.message, confirmButtonColor: '#dc2626' });
                }
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể lưu. Vui lòng thử lại.', confirmButtonColor: '#dc2626' });
            }
        });
    }

    function loadViolationsBySemester(semesterId) {
        $('#vSemesterId').val(semesterId);
        $.ajax({
            url: '@Url.Action("GetViolationsBySemester", "Homeroom")',
            type: 'GET',
            data: { semesterId: semesterId },
            success: function(html) {
                $('#violationListContainer').html(html);
                // Re-apply search filter after loading
                var term = document.getElementById('searchInput').value;
                if (term) {
                    (function() {
                        term = term.toLowerCase().trim();
                        var rows = document.querySelectorAll('.violation-row');
                        var visibleCount = 0;
                        rows.forEach(function(row) {
                            var name = row.getAttribute('data-name') || '';
                            var code = row.getAttribute('data-code') || '';
                            var matches = !term || name.includes(term) || code.includes(term);
                            row.style.display = matches ? '' : 'none';
                            if (matches) visibleCount++;
                        });
                        var countEl = document.getElementById('searchCount');
                        var clearBtn = document.getElementById('btnClearSearch');
                        if (term) {
                            countEl.textContent = visibleCount + ' vi phạm';
                            clearBtn.classList.remove('hidden');
                        } else {
                            countEl.textContent = '';
                            clearBtn.classList.add('hidden');
                        }
                    })();
                }
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể tải danh sách.', confirmButtonColor: '#dc2626' });
            }
        });
    }

    function deleteViolation(id) {
        var semesterId = parseInt(document.getElementById('vSemesterId').value) || 0;
        Swal.fire({
            icon: 'warning',
            title: 'Xác nhận xóa',
            text: 'Bạn có chắc chắn muốn xóa vi phạm này?',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Xóa',
            cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (!result.isConfirmed) return;
            $.ajax({
                url: '@Url.Action("DeleteViolation", "Homeroom")',
                type: 'DELETE',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                data: { id: id },
                success: function(res) {
                    if (res.success) {
                        $('tr[data-id="' + id + '"]').remove();
                        Swal.fire({ icon: 'success', title: 'Đã xóa', text: res.message, confirmButtonColor: '#006b2c' });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: res.message, confirmButtonColor: '#dc2626' });
                    }
                },
                error: function() {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể xóa.', confirmButtonColor: '#dc2626' });
                }
            });
        });
    }
</script>
