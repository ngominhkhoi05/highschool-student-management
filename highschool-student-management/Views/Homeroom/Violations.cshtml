@model List<highschool_student_management.ViewModels.ViolationIndexViewModel>

@{
    var semesters = ViewData["Semesters"] as List<highschool_student_management.ViewModels.SemesterDropdown> ?? new();
    var violationTypes = ViewData["ViolationTypes"] as List<highschool_student_management.ViewModels.ViolationTypeDropdown> ?? new();
    var students = ViewData["Students"] as List<highschool_student_management.ViewModels.StudentDropdown> ?? new();
    var selectedSemesterId = semesters.FirstOrDefault()?.Id ?? 0;
    var classId = (int)(ViewData["ClassId"] ?? 0);
    var className = ViewData["ClassName"]?.ToString() ?? "";
    ViewData["Title"] = "Theo doi vi pham";
    // DEBUG: @semesters.Count sems, @students.Count students
}

<div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-red-500">report</span>
            <div>
                <h2 class="text-xl font-bold text-slate-800">Theo doi vi pham</h2>
                <p class="text-sm text-slate-500">@className</p>
            </div>
        </div>
        <button onclick="openAddViolationModal()"
                class="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add</span>
            Them vi pham
        </button>
    </div>

    <!-- Bo loc hoc ky -->
    <div class="bg-white rounded-xl p-4 mb-4 flex flex-wrap gap-3 items-center border border-green-100">
        <label class="text-sm font-semibold text-slate-600">Hoc ky:</label>
        @foreach (var sem in semesters)
        {
            <button onclick="loadViolationsBySemester(@sem.Id)"
                    data-semester-id="@sem.Id"
                    class="semester-btn px-4 py-2 rounded-lg text-sm font-medium transition-all @(sem.Id == selectedSemesterId ? "bg-green-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-green-50")">
                @sem.Name
            </button>
        }
    </div>

    <!-- Bang vi pham -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <div id="violationListContainer">
            @if (Model == null || !Model.Any())
            {
                <div class="p-12 text-center text-slate-400">
                    <span class="material-symbols-outlined text-5xl">check_circle</span>
                    <p class="mt-3 text-slate-500 font-medium">Chua co vi pham nao</p>
                    <p class="text-sm mt-1">Danh sach vi pham trong hoc ky nay se hien thi o day.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-red-50 text-red-700">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold">Ngay</th>
                                <th class="px-4 py-3 text-left font-semibold">Ma HS</th>
                                <th class="px-4 py-3 text-left font-semibold">Ho va ten</th>
                                <th class="px-4 py-3 text-left font-semibold">Loai vi pham</th>
                                <th class="px-4 py-3 text-center font-semibold">Muc do</th>
                                <th class="px-4 py-3 text-left font-semibold">Mo ta</th>
                                <th class="px-4 py-3 text-center font-semibold">Hanh dong</th>
                                <th class="px-4 py-3 text-center font-semibold w-16"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model)
                            {
                                var severityClass = v.Severity switch
                                {
                                    1 => "bg-yellow-100 text-yellow-700",
                                    2 => "bg-orange-100 text-orange-700",
                                    3 => "bg-red-100 text-red-700",
                                    _ => "bg-slate-100 text-slate-600"
                                };
                                var severityText = v.Severity switch
                                {
                                    1 => "Nhe",
                                    2 => "Trung binh",
                                    3 => "Nang",
                                    _ => "-"
                                };
                                var actionText = v.ActionTaken switch
                                {
                                    1 => "Nhac nho",
                                    2 => "Phat lao dong",
                                    3 => "Moi phu huynh",
                                    4 => "Ky luat",
                                    _ => "-"
                                };
                                <tr class="odd:bg-white even:bg-red-50/20 hover:bg-red-50/40 transition-colors" data-id="@v.Id">
                                    <td class="px-4 py-3 text-slate-600">@v.ViolationDate.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3 font-medium text-green-700">@v.StudentCode</td>
                                    <td class="px-4 py-3 font-semibold text-slate-800">@v.StudentName</td>
                                    <td class="px-4 py-3 text-slate-600">@v.ViolationTypeName</td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="px-2 py-1 rounded-full text-xs font-bold @severityClass">@severityText</span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">@(v.Description ?? "-")</td>
                                    <td class="px-4 py-3 text-center text-xs text-slate-500">@actionText</td>
                                    <td class="px-4 py-3 text-center">
                                        <button onclick="deleteViolation(@v.Id)"
                                                class="text-red-400 hover:text-red-600 transition-colors p-1 rounded hover:bg-red-50"
                                                title="Xoa">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Popup them vi pham -->
<div id="addViolationModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
        <div class="bg-red-600 px-6 py-4 flex items-center justify-between">
            <h3 class="text-white font-bold text-lg flex items-center gap-2">
                <span class="material-symbols-outlined">report</span>
                Them vi pham
            </h3>
            <button onclick="closeAddViolationModal()" class="text-white/80 hover:text-white transition-colors">
                <span class="material-symbols-outlined text-2xl">close</span>
            </button>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Hoc ky <span class="text-red-500">*</span></label>
                <select id="vSemesterId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chon hoc ky --</option>
                    @foreach (var sem in semesters)
                    {
                        <option value="@sem.Id">@sem.Name</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Hoc sinh <span class="text-red-500">*</span></label>
                <select id="vStudentId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chon hoc sinh --</option>
                    @foreach (var s in students)
                    {
                        <option value="@s.StudentId">@s.StudentCode - @s.FullName</option>
                    }
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Loai vi pham <span class="text-red-500">*</span></label>
                <select id="vTypeId"
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                    <option value="">-- Chon loai vi pham --</option>
                    @foreach (var vt in violationTypes)
                    {
                        var sevText = vt.Severity switch { 1 => "Nhe", 2 => "Trung binh", _ => "Nang" };
                        <option value="@vt.Id" data-severity="@vt.Severity" data-deduct="@vt.DeductPoints">@vt.Name (@sevText, -@vt.DeductPoints diem)</option>
                    }
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-600 mb-2">Ngay vi pham <span class="text-red-500">*</span></label>
                    <input type="date" id="vDate"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")"
                           class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-600 mb-2">Hanh dong xu ly</label>
                    <select id="vAction"
                            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 bg-white">
                        <option value="">-- Chon --</option>
                        <option value="1">Nhac nho</option>
                        <option value="2">Phat lao dong</option>
                        <option value="3">Moi phu huynh</option>
                        <option value="4">Ky luat</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-2">Mo ta</label>
                <textarea id="vDesc"
                          rows="3"
                          placeholder="Mo ta chi tiet vi pham..."
                          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-red-500/20 focus:border-red-400 placeholder:text-slate-300"></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <button onclick="closeAddViolationModal()"
                        class="flex-1 px-4 py-2.5 border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-semibold rounded-xl transition-all">
                    Dong
                </button>
                <button onclick="saveViolation()"
                        class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-base">save</span>
                    Ghi nhan
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openAddViolationModal() {
        // Tu dong chon hoc ky dang active trong dropdown
        var activeBtn = document.querySelector('.semester-btn.bg-green-600');
        if (activeBtn) {
            var activeSemesterId = activeBtn.getAttribute('data-semester-id');
            if (activeSemesterId) {
                $('#vSemesterId').val(activeSemesterId);
            }
        }
        $('#addViolationModal').removeClass('hidden').addClass('flex');
    }

    function closeAddViolationModal() {
        $('#addViolationModal').removeClass('flex').addClass('hidden');
        document.getElementById('vSemesterId').value = '';
        document.getElementById('vStudentId').value = '';
        document.getElementById('vTypeId').value = '';
        document.getElementById('vAction').value = '';
        document.getElementById('vDesc').value = '';
        document.getElementById('vDate').value = '@DateTime.Now.ToString("yyyy-MM-dd")';
    }

    function saveViolation() {
        var semesterId = parseInt($('#vSemesterId').val()) || 0;
        var studentId = parseInt($('#vStudentId').val()) || 0;
        var typeId = parseInt($('#vTypeId').val()) || 0;
        var date = $('#vDate').val();
        var action = parseInt($('#vAction').val()) || 0;
        var desc = $('#vDesc').val();

        console.log('[DEBUG saveViolation] semesterId:', semesterId, '| vSemesterId val:', $('#vSemesterId').val());
        if (!semesterId) {
            Swal.fire({ icon: 'warning', title: 'Thieu thong tin', text: 'Vui long chon hoc ky.', confirmButtonColor: '#dc2626' });
            return;
        }
        if (!studentId || !typeId || !date) {
            Swal.fire({ icon: 'warning', title: 'Thieu thong tin', text: 'Vui long chon hoc sinh, loai vi pham va ngay vi pham.', confirmButtonColor: '#dc2626' });
            return;
        }

        $.ajax({
            url: '@Url.Action("CreateViolation", "Homeroom")',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: JSON.stringify({
                studentId: studentId,
                violationTypeId: typeId,
                semesterId: semesterId,
                violationDate: date,
                description: desc || null,
                actionTaken: action > 0 ? action : null
            }),
            success: function(result) {
                console.log('[DEBUG ajax success]', result);
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'Thanh cong!', text: result.message, confirmButtonColor: '#006b2c' }).then(function() {
                        closeAddViolationModal();
                        loadViolationsBySemester(semesterId);
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Loi', text: result.message, confirmButtonColor: '#dc2626' });
                }
            },
            error: function(xhr) {
                console.log('[DEBUG ajax error]', xhr.responseText);
                Swal.fire({ icon: 'error', title: 'Loi', text: 'Khong the luu. Vui long thu lai.', confirmButtonColor: '#dc2626' });
            }
        });
    }

    function loadViolationsBySemester(semesterId) {
        $('#vSemesterId').val(semesterId);
        $.ajax({
            url: '@Url.Action("GetViolationsBySemester", "Homeroom")',
            type: 'GET',
            data: { semesterId: semesterId },
            success: function(html) {
                $('#violationListContainer').html(html);
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Loi', text: 'Khong the tai danh sach.', confirmButtonColor: '#dc2626' });
            }
        });
    }

    function deleteViolation(id) {
        var semesterId = parseInt(document.getElementById('vSemesterId').value) || 0;
        Swal.fire({
            icon: 'warning',
            title: 'Xac nhan xoa',
            text: 'Ban co chac chan muon xoa vi pham nay?',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Xoa',
            cancelButtonText: 'Huy'
        }).then(function(result) {
            if (!result.isConfirmed) return;
            $.ajax({
                url: '@Url.Action("DeleteViolation", "Homeroom")',
                type: 'DELETE',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                data: { id: id },
                success: function(res) {
                    if (res.success) {
                        $('tr[data-id="' + id + '"]').remove();
                        Swal.fire({ icon: 'success', title: 'Da xoa', text: res.message, confirmButtonColor: '#006b2c' });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Loi', text: res.message, confirmButtonColor: '#dc2626' });
                    }
                },
                error: function() {
                    Swal.fire({ icon: 'error', title: 'Loi', text: 'Khong the xoa.', confirmButtonColor: '#dc2626' });
                }
            });
        });
    }
</script>
