@model List<highschool_student_management.ViewModels.ConductScoreIndexViewModel>

@if (Model == null || !Model.Any())
{
    <div class="p-12 text-center text-slate-400">
        <span class="material-symbols-outlined text-5xl">groups</span>
        <p class="mt-3 text-slate-500 font-medium">Chưa có học sinh nào trong lớp</p>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table id="conductTable" class="w-full text-sm">
            <thead class="bg-amber-50 text-amber-700">
                <tr>
                    <th class="px-4 py-3 text-center font-semibold w-12">STT</th>
                    <th class="px-4 py-3 text-left font-semibold">Mã HS</th>
                    <th class="px-4 py-3 text-left font-semibold">Họ và tên</th>
                    <th class="px-4 py-3 text-center font-semibold">Vi phạm</th>
                    <th class="px-4 py-3 text-center font-semibold w-40">Xếp loại</th>
                    <th class="px-4 py-3 text-center font-semibold w-28">Điểm</th>
                    <th class="px-4 py-3 text-left font-semibold">Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var stt = 1;
                    foreach (var cs in Model)
                    {
                        var hasViolation = cs.HasViolationRecord;
                        <tr data-id="@cs.Id" data-student-id="@cs.StudentId"
                            class="odd:bg-white even:bg-amber-50/20 hover:bg-amber-50/40 transition-colors @(hasViolation ? "bg-red-50/20" : "")">
                            <td class="px-4 py-3 text-center text-slate-400 text-xs font-medium">@stt</td>
                            <td class="px-4 py-3 font-medium text-green-700">@cs.StudentCode</td>
                            <td class="px-4 py-3 font-semibold text-slate-800">@cs.StudentName</td>
                            <td class="px-4 py-3 text-center">
                                @if (hasViolation)
                                {
                                    <span class="material-symbols-outlined text-red-500 text-lg" title="Có vi phạm">warning</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-green-400 text-lg" title="Không có vi phạm">check_circle</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <select class="rank-select w-full px-2 py-1.5 border rounded-lg text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-400 bg-white @(cs.Id > 0 ? "border-amber-300 bg-amber-50" : "border-slate-200")">
                                    <option value="0">-- Chọn --</option>
                                    @if (cs.ConductRank == 1)
                                    {
                                        <option value="1" selected>Tốt</option>
                                    }
                                    else
                                    {
                                        <option value="1">Tốt</option>
                                    }
                                    @if (cs.ConductRank == 2)
                                    {
                                        <option value="2" selected>Khá</option>
                                    }
                                    else
                                    {
                                        <option value="2">Khá</option>
                                    }
                                    @if (cs.ConductRank == 3)
                                    {
                                        <option value="3" selected>Trung bình</option>
                                    }
                                    else
                                    {
                                        <option value="3">Trung bình</option>
                                    }
                                    @if (cs.ConductRank == 4)
                                    {
                                        <option value="4" selected>Yếu</option>
                                    }
                                    else
                                    {
                                        <option value="4">Yếu</option>
                                    }
                                </select>
                            </td>
                            <td class="px-4 py-3">
                                <input type="number" min="0" max="100"
                                       class="score-input w-full px-3 py-1.5 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-400 text-center @(cs.Id > 0 ? "border-amber-300 bg-amber-50" : "")"
                                       value="@(cs.Score?.ToString() ?? "")"
                                       placeholder="0-100" />
                            </td>
                            <td class="px-4 py-3">
                                <input type="text"
                                       class="note-input w-full px-3 py-1.5 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-400 placeholder:text-slate-300"
                                       placeholder="Ghi chú..."
                                       value="@(cs.Note ?? "")" />
                            </td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="px-4 py-3 bg-slate-50 text-xs text-slate-400 flex items-center gap-2">
        <span class="material-symbols-outlined text-base">info</span>
        Dòng được tô nền đỏ là lịch sử đánh giá.
    </div>
}
