@model List<highschool_student_management.ViewModels.ConductScoreIndexViewModel>

@{
    var semesters = ViewData["Semesters"] as List<highschool_student_management.ViewModels.SemesterDropdown> ?? new();
    var selectedSemesterId = (int)(ViewData["SelectedSemesterId"] ?? 0);
    var classId = (int)(ViewData["ClassId"] ?? 0);
    var className = ViewData["ClassName"]?.ToString() ?? "";
    ViewData["Title"] = "Đánh giá hạnh kiểm";
}

<div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl text-amber-500">stars</span>
            <div>
                <h2 class="text-xl font-bold text-slate-800">Đánh giá hạnh kiểm</h2>
                <p class="text-sm text-slate-500">@className</p>
            </div>
        </div>
        <button onclick="saveConductScores()"
                class="px-5 py-2.5 bg-amber-600 hover:bg-amber-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-base">save</span>
            Lưu hạnh kiểm
        </button>
    </div>

    <!-- Bo loc hoc ky -->
    <div class="bg-white rounded-xl p-4 mb-4 flex flex-wrap gap-3 items-center border border-green-100">
        <label class="text-sm font-semibold text-slate-600">Học kỳ:</label>
        @foreach (var sem in semesters)
        {
            <button onclick="loadConductBySemester(@sem.Id)"
                    class="px-4 py-2 rounded-lg text-sm font-medium transition-all @(sem.Id == selectedSemesterId ? "bg-green-600 text-white" : "bg-slate-100 text-slate-600 hover:bg-green-50")">
                @sem.Name
            </button>
        }
    </div>

    <!-- Bang hanh kiem -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
        <!-- Thanh tim kiem -->
        <div class="p-3 border-b border-amber-100 flex items-center gap-3 bg-amber-50/30">
            <div class="relative flex-1 max-w-xs">
                <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400 text-base">search</span>
                <input type="text"
                       id="searchInput"
                       placeholder="Tìm kiếm theo tên hoặc mã HS..."
                       class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-400 transition-all placeholder:text-slate-300" />
            </div>
            <span id="searchCount" class="text-xs text-slate-400"></span>
            <button id="btnClearSearch"
                    type="button"
                    class="hidden px-3 py-1.5 text-xs font-medium text-slate-500 hover:bg-slate-100 rounded-lg transition-all">
                Xóa lọc
            </button>
        </div>

        <div id="conductListContainer">
            @await Html.PartialAsync("_ConductScoreList", Model)
        </div>
    </div>
</div>

<script>
    var gSemesterId = @selectedSemesterId;
    var gClassId = @classId;
    var searchTimer = null;

    function applySearchFilter(term) {
        term = term.toLowerCase().trim();
        var rows = document.querySelectorAll('.conduct-row');
        var visibleCount = 0;
        rows.forEach(function(row) {
            var name = row.getAttribute('data-name') || '';
            var code = row.getAttribute('data-code') || '';
            var matches = !term || name.includes(term) || code.includes(term);
            row.style.display = matches ? '' : 'none';
            if (matches) visibleCount++;
        });

        // Re-number visible rows
        var visibleRows = document.querySelectorAll('.conduct-row:not([style*="display: none"])');
        visibleRows.forEach(function(row, i) {
            var sttEl = row.querySelector('td:first-child');
            if (sttEl) sttEl.textContent = i + 1;
        });

        var countEl = document.getElementById('searchCount');
        var clearBtn = document.getElementById('btnClearSearch');
        if (term) {
            countEl.textContent = visibleCount + ' học sinh';
            clearBtn.classList.remove('hidden');
        } else {
            countEl.textContent = '';
            clearBtn.classList.add('hidden');
        }
    }

    function loadConductBySemester(semesterId) {
        gSemesterId = semesterId;
        $.ajax({
            url: '@Url.Action("GetConductScoresBySemester", "Homeroom")',
            type: 'GET',
            data: { semesterId: semesterId },
            success: function(html) {
                $('#conductListContainer').html(html);
                var term = document.getElementById('searchInput').value;
                if (term) applySearchFilter(term);
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể tải danh sách.', confirmButtonColor: '#d97706' });
            }
        });
    }

    $(document).ready(function() {
        $('#searchInput').on('input', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(function() {
                applySearchFilter(document.getElementById('searchInput').value);
            }, 300);
        });

        $('#btnClearSearch').on('click', function() {
            document.getElementById('searchInput').value = '';
            applySearchFilter('');
        });
    });

    function saveConductScores() {
        var items = [];

        $('#conductTable tbody tr').each(function() {
            var id = parseInt($(this).data('id')) || 0;
            var studentId = parseInt($(this).data('student-id'));
            var rank = parseInt($(this).find('.rank-select').val()) || 0;
            var score = parseInt($(this).find('.score-input').val()) || 0;
            var note = $(this).find('.note-input').val();

            items.push({
                id: id,
                studentId: studentId,
                semesterId: gSemesterId,
                conductRank: rank > 0 ? rank : null,
                score: score > 0 ? score : null,
                note: note || null
            });
        });

        $.ajax({
            url: '@Url.Action("SaveConductScores", "Homeroom")',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: JSON.stringify(items),
            success: function(result) {
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'Thành công!', text: result.message, confirmButtonColor: '#006b2c' });
                } else {
                    Swal.fire({ icon: 'error', title: 'Loi', text: result.message, confirmButtonColor: '#d97706' });
                }
            },
            error: function() {
                Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể lưu. Vui lòng thử lại.', confirmButtonColor: '#d97706' });
            }
        });
    }
</script>
