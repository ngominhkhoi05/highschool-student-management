@model highschool_student_management.ViewModels.HomeroomClassViewModel

@{
    ViewData["Title"] = "Lớp chủ nhiệm";
}

@if (ViewData["NoClass"] != null && (bool)ViewData["NoClass"] == true)
{
    <div class="bg-white rounded-2xl shadow-sm border border-green-100 p-12 text-center">
        <span class="material-symbols-outlined text-6xl text-slate-300">school</span>
        <h3 class="mt-4 text-lg font-semibold text-slate-500">Bạn chưa có lớp chủ nhiệm</h3>
        <p class="mt-2 text-sm text-slate-400">Vui lòng liên hệ quản trị để được phân công lớp chủ nhiệm.</p>
    </div>
}
else
{
    <div class="max-w-5xl mx-auto">
        <!-- Thong tin lop -->
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden mb-6">
            <div class="bg-green-600 px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-white text-2xl">meeting_room</span>
                    <div>
                        <h2 class="text-white font-bold text-lg">@Model.ClassName</h2>
                        <p class="text-green-200 text-xs">@Model.SchoolYearName</p>
                    </div>
                </div>
                <div class="flex items-center gap-6 text-green-100 text-sm">
                    <div class="text-center">
                        <p class="text-2xl font-bold text-white">@Model.StudentCount</p>
                        <p class="text-xs">Học sinh</p>
                    </div>
                    @if (Model.GradeLevel != null)
                    {
                        <div class="text-center">
                            <p class="text-2xl font-bold text-white">@Model.GradeLevel</p>
                            <p class="text-xs">Khối</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Room))
                    {
                        <div class="text-center">
                            <span class="material-symbols-outlined text-white text-xl">room</span>
                            <p class="text-xs">@Model.Room</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Danh sach hoc sinh -->
        <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
            <div class="bg-green-600 px-6 py-3 flex items-center justify-between">
                <h3 class="text-white font-bold">Danh sách học sinh</h3>
                <!-- Thanh tim kiem -->
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-green-200 text-base">search</span>
                        <input type="text"
                               id="searchInput"
                               placeholder="Tìm kiếm..."
                               class="pl-9 pr-3 py-1.5 bg-green-500/20 border border-green-400/30 text-white text-sm rounded-lg placeholder:text-green-200/60 focus:outline-none focus:bg-green-500/30 w-52" />
                    </div>
                    <span id="searchCount" class="text-green-200 text-xs"></span>
                    <button id="btnClearSearch"
                            type="button"
                            class="hidden px-3 py-1.5 text-xs font-medium text-green-200 hover:text-white hover:bg-green-500/30 rounded-lg transition-all">
                        Xóa lọc
                    </button>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm" id="studentTable">
                    <thead class="bg-green-50 text-slate-600">
                        <tr>
                            <th class="px-4 py-3 text-center font-semibold w-12">STT</th>
                            <th class="px-4 py-3 text-left font-semibold">Mã HS</th>
                            <th class="px-4 py-3 text-left font-semibold">Họ và tên</th>
                            <th class="px-4 py-3 text-center font-semibold">Giới tính</th>
                            <th class="px-4 py-3 text-center font-semibold">Ngày sinh</th>
                            <th class="px-4 py-3 text-center font-semibold">Số điện thoại</th>
                            <th class="px-4 py-3 text-center font-semibold">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var stt = 1;
                            foreach (var s in Model.Students)
                            {
                                var statusClass = s.Status switch
                                {
                                    1 => "bg-green-100 text-green-700",
                                    2 => "bg-yellow-100 text-yellow-700",
                                    3 => "bg-blue-100 text-blue-700",
                                    _ => "bg-slate-100 text-slate-600"
                                };
                                var statusText = s.Status switch
                                {
                                    1 => "Đang học",
                                    2 => "Nghỉ học",
                                    3 => "Tốt nghiệp",
                                    _ => "Khác"
                                };
                                var genderText = s.Gender == 1 ? "Nam" : s.Gender == 2 ? "Nữ" : "-";
                                <tr class="student-row odd:bg-white even:bg-green-50/30 hover:bg-green-100/30 transition-colors"
                                    data-code="@s.StudentCode.ToLower()"
                                    data-name="@s.FullName.ToLower()">
                                    <td class="px-4 py-3 text-center text-slate-400 text-xs font-medium stt-col">@stt</td>
                                    <td class="px-4 py-3 font-medium text-green-700">@s.StudentCode</td>
                                    <td class="px-4 py-3 font-semibold text-slate-800">@s.FullName</td>
                                    <td class="px-4 py-3 text-center text-slate-600">@genderText</td>
                                    <td class="px-4 py-3 text-center text-slate-600">@(s.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="px-4 py-3 text-center text-slate-600">@(s.Phone ?? "-")</td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="px-2 py-1 rounded-full text-xs font-semibold @statusClass">@statusText</span>
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        (function() {
            var searchTimer = null;
            var totalRows = @Model.StudentCount;

            function doFilter(value) {
                var term = value.toLowerCase().trim();
                var rows = document.querySelectorAll('.student-row');
                var visibleCount = 0;

                rows.forEach(function(row) {
                    var name = row.getAttribute('data-name') || '';
                    var code = row.getAttribute('data-code') || '';

                    if (!term || name.includes(term) || code.includes(term)) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Re-number visible rows
                var visibleRows = document.querySelectorAll('.student-row:not([style*="display: none"])');
                visibleRows.forEach(function(row, i) {
                    var sttEl = row.querySelector('.stt-col');
                    if (sttEl) sttEl.textContent = i + 1;
                });

                // Update count
                var countEl = document.getElementById('searchCount');
                var clearBtn = document.getElementById('btnClearSearch');
                if (term) {
                    countEl.textContent = visibleCount + '/' + totalRows + ' học sinh';
                    clearBtn.classList.remove('hidden');
                } else {
                    countEl.textContent = '';
                    clearBtn.classList.add('hidden');
                }
            }

            document.getElementById('searchInput').addEventListener('input', function() {
                var value = this.value;
                clearTimeout(searchTimer);
                searchTimer = setTimeout(function() {
                    doFilter(value);
                }, 300);
            });

            document.getElementById('btnClearSearch').addEventListener('click', function() {
                var input = document.getElementById('searchInput');
                input.value = '';
                doFilter('');
            });
        })();
    </script>
}
